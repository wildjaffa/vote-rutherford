# Environment variables for Vote Rutherford

# Database Configuration
# For local development, use localhost
# For Docker development, use the service name 'database'
DATABASE_URL="postgresql://username:password@localhost:5432/default_database?schema=public"

# Optional: Customize database credentials
# POSTGRES_USER=username
# POSTGRES_PASSWORD=password
# POSTGRES_DB=default_database

# Cloudflare Cache Invalidation
CLOUDFLARE_ZONE_ID="your_zone_id"
CLOUDFLARE_API_TOKEN="your_api_token"
PUBLIC_SITE_URL="https://govoterutherford.com"

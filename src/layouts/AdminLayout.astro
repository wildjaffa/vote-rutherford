---
import { Home, Vote } from "@lucide/astro";
import Layout from "./Layout.astro";

interface Props {
  title: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
}

const { title, breadcrumbs = [] } = Astro.props;
---

<Layout title={`Admin - ${title}`}>
  <!-- Admin Header -->
  <div class="bg-secondary text-white shadow-md">
    <div class="container mx-auto px-4 py-4">
      <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">Admin Dashboard</h1>
        <a
          href="/"
          class="inline-flex items-center px-4 py-2 bg-white text-secondary rounded-lg hover:bg-gray-100 transition-colors"
        >
          <Home size="16" stroke-width={2} class="mr-2" />
          Back to Site
        </a>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Sidebar Navigation -->
      <aside class="lg:w-64 shrink-0">
        <nav class="bg-white rounded-lg shadow-md p-4 sticky top-4">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Admin Menu</h2>
          <ul class="space-y-2">
            <li>
              <a
                href="/admin/elections"
                class="flex items-center px-4 py-2 text-gray-700 hover:bg-secondary hover:text-white rounded-lg transition-colors"
              >
                <Vote size="18" stroke-width={2} class="mr-3" />
                Elections
              </a>
            </li>
          </ul>

          <!-- Help Section -->
          <div class="mt-8 pt-6 border-t border-gray-200">
            <h3 class="text-sm font-semibold text-gray-700 mb-3">
              Quick Links
            </h3>
            <ul class="space-y-2 text-sm">
              <li>
                <a
                  href="/admin/elections"
                  class="text-secondary hover:text-secondary/80 transition-colors"
                >
                  → Manage Elections
                </a>
              </li>
              <li>
                <a
                  href="/"
                  class="text-secondary hover:text-secondary/80 transition-colors"
                >
                  → View Public Site
                </a>
              </li>
            </ul>
          </div>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="flex-1">
        <!-- Breadcrumbs -->
        {
          breadcrumbs.length > 0 && (
            <nav class="mb-6" aria-label="Breadcrumb">
              <ol class="flex items-center space-x-2 text-sm text-gray-600">
                <li>
                  <a
                    href="/admin/elections"
                    class="hover:text-secondary transition-colors"
                  >
                    Admin
                  </a>
                </li>
                {breadcrumbs.map((crumb) => (
                  <>
                    <li>
                      <span class="text-gray-400">/</span>
                    </li>
                    <li>
                      {crumb.href ? (
                        <a
                          href={crumb.href}
                          class="hover:text-secondary transition-colors"
                        >
                          {crumb.label}
                        </a>
                      ) : (
                        <span class="text-gray-900 font-medium">
                          {crumb.label}
                        </span>
                      )}
                    </li>
                  </>
                ))}
              </ol>
            </nav>
          )
        }

        <!-- Page Title -->
        <div class="mb-6">
          <h2 class="text-3xl font-bold text-gray-900">{title}</h2>
        </div>

        <!-- Page Content -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <slot />
        </div>
      </main>
    </div>
  </div>
</Layout>

---
import VotePlanRace from "./VotePlanRace.astro";
import { PartyCategories } from "../constants";
import prisma from "../lib/prisma";
import { DistrictType } from "../generated/prisma/browser";
import AddressSearch from "./AddressSearch.astro";
import { SquareCheckBig } from "../lib/icons";

// Inside a server island we can access Astro.url and Astro.cookies.
const addressId = Astro.url.searchParams.get("addressId");
const cookieAddressId = Astro.cookies.get("voterAddressId")?.value;

const selectedAddressId = addressId || cookieAddressId;

let error: string | null = null;

let voterAddress: {
  normalizedAddress: string;
  city: string | null;
  zip: string | null;
} | null = null;
const districtRaces = [];

// Fetch everything we need in one query to avoid N+1 issues.
if (!selectedAddressId) {
  const globalDistrictData = await prisma.district.findMany({
    where: {
      deletedAt: null,
      type: DistrictType.ALL,
    },
    include: {
      races: {
        orderBy: { election: { date: "asc" } },
        where: {
          deletedAt: null,
        },
        include: {
          election: true,
          raceType: true,
          candidates: {
            where: { deletedAt: null },
          },
        },
      },
    },
  });
  districtRaces.push(...globalDistrictData.flatMap((d) => d.races ?? []));
} else {
  const voterAddressData = await prisma.voterAddress.findUnique({
    where: { id: selectedAddressId },
    include: {
      districts: {
        include: {
          district: {
            include: {
              races: {
                orderBy: { election: { date: "asc" } },
                where: {
                  deletedAt: null,
                },
                include: {
                  election: true,
                  raceType: true,
                  candidates: {
                    where: { deletedAt: null },
                  },
                },
              },
            },
          },
        },
      },
    },
  });

  if (!voterAddressData) {
    error = "Address not found. Please search for your address again.";
  } else {
    voterAddress = {
      normalizedAddress: voterAddressData.normalizedAddress,
      city: voterAddressData.city,
      zip: voterAddressData.zip,
    };

    // Work with races for the first matched district (preserve existing behavior)
    districtRaces.push(
      ...voterAddressData.districts.flatMap((d) => d.district.races ?? []),
    );
  }
}

// Single pass: validate races, track elections, find best election
const validRaces: typeof districtRaces = [];
const electionMap = new Map<string, (typeof districtRaces)[0]["election"]>();

let closestFutureElection: (typeof districtRaces)[0]["election"] | null = null;
let closestFutureDistance = Infinity;
let mostRecentPastElection: (typeof districtRaces)[0]["election"] | null = null;
let mostRecentPastDistance = -Infinity;

const now = new Date();
const nowTime = now.getTime();

for (const race of districtRaces) {
  if (!race || race.deletedAt || !race.election || race.election.deletedAt) {
    continue;
  }

  validRaces.push(race);
  const electionId = race.election.id;

  // Deduplicate elections via Map (each ID tracked once)
  if (!electionMap.has(electionId)) {
    const election = race.election;

    if (!election.archivedAt) {
      const electionTime = new Date(election.date).getTime();
      const distance = electionTime - nowTime;

      // Track closest future election (smallest positive distance)
      if (distance >= 0 && distance < closestFutureDistance) {
        closestFutureElection = election;
        closestFutureDistance = distance;
      }
      // Track most recent past election (largest negative distance, i.e., closest to now)
      else if (distance < 0 && distance > mostRecentPastDistance) {
        mostRecentPastElection = election;
        mostRecentPastDistance = distance;
      }
    }

    electionMap.set(electionId, election);
  }
}

// Use closest future, fallback to most recent past
const election = closestFutureElection || mostRecentPastElection;

// Filter races to the selected election (O(n) but small n)
const races = election
  ? validRaces
      .filter((r) => r.election && r.election.id === election.id)
      .sort((a, b) => {
        const typeDiff = b.raceType.id - a.raceType.id;
        if (typeDiff !== 0) return typeDiff;
        return a.name.localeCompare(b.name, undefined, {
          numeric: true,
          sensitivity: "base",
        });
      })
  : [];

// Efficiently group into sections for display while maintaining sort order
const raceTypeLabels: Record<number, string> = {
  4: "Federal",
  3: "State",
  2: "County",
  1: "City",
};

interface RaceSection {
  label: string;
  races: typeof races;
}

const raceSections: RaceSection[] = [];
let lastTypeId = -1;

for (const race of races) {
  const typeId = race.raceType.id;
  if (typeId !== lastTypeId) {
    raceSections.push({
      label:
        raceTypeLabels[typeId] || (race.raceType.value as string) || "Other",
      races: [race],
    });
    lastTypeId = typeId;
  } else {
    const lastSection = raceSections[raceSections.length - 1];
    if (lastSection) {
      lastSection.races.push(race);
    }
  }
}

const hasDemocraticPrimary = races.some(
  (r) => r.partyCategory === PartyCategories.DEMOCRATIC,
);
const hasRepublicanPrimary = races.some(
  (r) => r.partyCategory === PartyCategories.REPUBLICAN,
);
const showPrimaryFilters = hasDemocraticPrimary && hasRepublicanPrimary;

const clientRaces = races.map((r) => ({
  id: r.id,
  name: r.name,
  shortName: r.shortName,
  typeLabel:
    raceTypeLabels[r.raceType.id] || (r.raceType.value as string) || "Other",
  candidates: r.candidates.map((c) => ({
    id: c.id,
    name: `${c.firstName}${c.middleName ? " " + c.middleName : ""} ${c.lastName}`,
    party: c.partyAffiliation,
  })),
}));
---

{
  !voterAddress && (
    <div class="mb-12">
      <AddressSearch class="col-span-12 md:col-span-8" />
    </div>
  )
}

<div class="mb-8">
  <h1 class="mb-2 text-4xl font-bold text-gray-900">
    {
      election &&
        `${election.name} (${new Date(election.date).toLocaleDateString()})`
    }
  </h1>
  {
    voterAddress && (
      <p class="text-lg text-gray-600">
        Address:{" "}
        <span class="font-semibold">
          {voterAddress.normalizedAddress}, {voterAddress.city}{" "}
          {voterAddress.zip}
        </span>
        <button
          id="change-address-btn"
          class="text-secondary ml-2 cursor-pointer underline"
        >
          Change Address
        </button>
      </p>
    )
  }
  {
    !voterAddress && (
      <p class="text-lg text-gray-600">
        Elections applicable to all residents of Rutherford County
      </p>
    )
  }
</div>

{
  showPrimaryFilters && (
    <div class="mb-8 flex flex-wrap gap-3" id="primary-filters">
      <button
        class="primary-filter-btn bg-secondary flex-1 rounded-full px-4 py-2 text-sm font-semibold text-white transition-colors hover:opacity-90 md:flex-none"
        data-filter="All"
      >
        All
      </button>
      <button
        class="primary-filter-btn bg-secondary flex-1 rounded-full px-4 py-2 text-sm font-semibold text-white transition-colors hover:opacity-90 md:flex-none"
        data-filter={PartyCategories.DEMOCRATIC}
      >
        Democratic Primary
      </button>
      <button
        class="primary-filter-btn bg-secondary flex-1 rounded-full px-4 py-2 text-sm font-semibold text-white transition-colors hover:opacity-90 md:flex-none"
        data-filter={PartyCategories.REPUBLICAN}
      >
        Republican Primary
      </button>
    </div>
  )
}

{
  error && (
    <div class="mb-8 rounded-lg border border-red-200 bg-red-50 p-4 text-red-700">
      <p>{error}</p>
      <button
        id="error-change-address-btn"
        class="mt-2 inline-block cursor-pointer font-semibold text-red-700 underline hover:text-red-800"
      >
        Search for your address
      </button>
    </div>
  )
}

{
  !error && races.length === 0 && election && (
    <div class="mb-8 rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-yellow-700">
      <p>No races found for this address in the {election.name} election.</p>
    </div>
  )
}

{
  raceSections.length > 0 && election && (
    <div class="space-y-12">
      {raceSections.map((section) => (
        <section>
          <div class="mb-8 flex items-center gap-6">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900">
              {section.label}
            </h2>
            <div class="h-px flex-1 bg-linear-to-r from-gray-200 to-transparent" />
          </div>
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {section.races.map((race) => (
              <VotePlanRace
                race={race}
                election={election}
                candidates={race.candidates}
              />
            ))}
          </div>
        </section>
      ))}

      <div class="mt-20 flex flex-col items-center justify-center pb-20">
        <button
          id="view-summary-btn"
          class="bg-primary hover:bg-primary/90 flex scale-95 cursor-pointer items-center gap-3 rounded-full px-10 py-5 text-xl font-bold text-white shadow-2xl transition-all duration-700 ease-in-out hover:scale-105 active:scale-95"
        >
          <SquareCheckBig size="24" />
          View My Ballot Summary
        </button>
      </div>
    </div>
  )
}

<!-- Summary Modal -->
<dialog
  id="summary-modal"
  class="fixed inset-0 z-100 m-auto h-fit max-h-[90vh] w-[98vw] max-w-4xl overflow-hidden rounded-2xl border-none bg-white p-0 shadow-2xl backdrop:bg-black/50 backdrop:backdrop-blur-sm"
>
  <div class="flex h-full max-h-[85vh] flex-col">
    <div
      class="bg-primary flex items-center justify-between border-b px-6 py-2 text-white"
    >
      <h2 class="text-2xl font-bold">Your Ballot Summary</h2>
      <!-- <button
        id="close-modal-btn"
        class="cursor-pointer text-white/80 transition-colors hover:text-white"
      >
        <X size="24" />
      </button> -->
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-2" id="summary-content">
      <!-- Content populated by JS -->
    </div>

    <div class="flex items-center justify-end border-t bg-gray-50 px-6 py-2">
      <button
        id="close-modal-footer-btn"
        class="bg-primary/10 text-primary hover:bg-primary/20 cursor-pointer rounded-lg px-6 py-2 font-semibold transition-colors"
      >
        Close
      </button>
    </div>
  </div>
</dialog>

{
  !error && !election && (
    <div class="mb-8 rounded-lg border border-blue-200 bg-blue-50 p-4 text-blue-700">
      <p>No elections are currently available.</p>
    </div>
  )
}

<script define:vars={{ clientRaces }}>
  const clearAddressAndReload = (e) => {
    e.preventDefault();
    // Clear voterAddressId cookie
    document.cookie = "voterAddressId=; max-age=0; path=/";
    // Redirect to home page / ballot page to search again
    window.location.href = "/my-ballot";
  };

  const changeAddressBtn = document.getElementById("change-address-btn");
  if (changeAddressBtn) {
    changeAddressBtn.addEventListener("click", clearAddressAndReload);
  }

  const errorChangeAddressBtn = document.getElementById(
    "error-change-address-btn",
  );
  if (errorChangeAddressBtn) {
    errorChangeAddressBtn.addEventListener("click", clearAddressAndReload);
  }

  // // Scroll visibility for summary button
  const viewSummaryBtn = document.getElementById("view-summary-btn");
  // if (viewSummaryBtn) {
  //   const handleScroll = () => {
  //     const scrollPosition = window.innerHeight + window.scrollY;
  //     const threshold = document.documentElement.scrollHeight - 300; // Trigger slightly before the absolute bottom

  //     if (scrollPosition >= threshold) {
  //       viewSummaryBtn.classList.remove(
  //         "opacity-0",
  //         "scale-95",
  //         "pointer-events-none",
  //       );
  //       viewSummaryBtn.classList.add(
  //         "opacity-100",
  //         "scale-100",
  //         "pointer-events-auto",
  //       );
  //     }
  //   };

  //   window.addEventListener("scroll", handleScroll);
  //   // Initial check in case they are already at bottom
  //   setTimeout(handleScroll, 500);
  // }

  // Modal logic
  const modal = document.getElementById("summary-modal");
  const closeModalBtns = [
    document.getElementById("close-modal-btn"),
    document.getElementById("close-modal-footer-btn"),
  ];
  const summaryContent = document.getElementById("summary-content");

  const STORAGE_KEY = "vote_plan_selections";

  const renderSummary = () => {
    const selections = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");

    if (Object.keys(selections).length === 0) {
      summaryContent.innerHTML = `
        <div class="py-12 text-center">
          <p class="text-gray-500 text-lg">You haven't made any selections yet.</p>
          <p class="text-gray-400">Close this and select your candidates to see a summary here.</p>
        </div>
      `;
      return;
    }

    const categories = {};
    clientRaces.forEach((race) => {
      const selectedIds = selections[race.id] || [];
      if (selectedIds.length === 0) return;

      if (!categories[race.typeLabel]) categories[race.typeLabel] = [];
      categories[race.typeLabel].push({
        ...race,
        selectedCandidates: race.candidates.filter((c) =>
          selectedIds.includes(c.id),
        ),
      });
    });

    let html = '<div class="space-y-4">';

    // Order categories by the same priority as the main list
    const labelOrder = ["Federal", "State", "County", "City"];
    const sortedCategories = Object.keys(categories).sort((a, b) => {
      const idxA = labelOrder.indexOf(a);
      const idxB = labelOrder.indexOf(b);
      if (idxA !== -1 && idxB !== -1) return idxA - idxB;
      if (idxA !== -1) return -1;
      if (idxB !== -1) return 1;
      return a.localeCompare(b);
    });

    sortedCategories.forEach((label) => {
      const races = categories[label];
      html += `
        <div>
          <div class="flex items-center gap-1 mb-1">
            <span class="text-[11px] font-black uppercase tracking-[0.2em] text-primary/40">${label}</span>
            <div class="h-px flex-1 bg-gray-100"></div>
          </div>
          <div class="grid grid-cols-2 gap-x-4 lg:grid-cols-3 sm:gap-x-12 gap-y-2">
            ${races
              .map(
                (race) => `
              <div class="min-w-0">
                <div class="text-[10px] font-bold text-gray-400 uppercase tracking-tight mb-1 truncate" title="${race.name}">${race.shortName || race.name}</div>
                <div class="space-y-1.5">
                  ${race.selectedCandidates
                    .map(
                      (c) => `
                    <div class="text-sm font-bold text-gray-900 flex items-start gap-2 leading-snug">
                       <div class="w-1.5 h-1.5 rounded-full bg-secondary mt-1 shrink-0"></div>
                       <div class="flex flex-col">
                         <span>${c.name}</span>
                         ${c.party ? `<span class="text-[10px] font-medium text-gray-500 uppercase tracking-tighter">(${c.party})</span>` : ""}
                       </div>
                    </div>
                  `,
                    )
                    .join("")}
                </div>
              </div>
            `,
              )
              .join("")}
          </div>
        </div>
      `;
    });

    html += "</div>";
    summaryContent.innerHTML = html;
  };

  viewSummaryBtn?.addEventListener("click", () => {
    renderSummary();
    modal?.showModal();
    document.body.style.overflow = "hidden"; // Prevent background scroll
  });

  const closeModal = () => {
    modal?.close();
    document.body.style.overflow = "auto";
  };

  closeModalBtns.forEach((btn) => btn?.addEventListener("click", closeModal));

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
</script>

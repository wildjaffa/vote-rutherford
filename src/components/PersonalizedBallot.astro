---
import VotePlanRace from "./VotePlanRace.astro";
import { PartyCategories } from "../constants";
import prisma from "../lib/prisma";
import { DistrictType } from "../generated/prisma/browser";
import AddressSearch from "./AddressSearch.astro";
import { SquareCheckBig, Share } from "../lib/icons";
import LogoImg from "../assets/Logo.png";

// Inside a server island we can access Astro.url and Astro.cookies.
const addressId = Astro.url.searchParams.get("addressId");
const cookieAddressId = Astro.cookies.get("voterAddressId")?.value;

const selectedAddressId = addressId || cookieAddressId;

let error: string | null = null;

let voterAddress: {
  normalizedAddress: string;
  city: string | null;
  zip: string | null;
} | null = null;
const districtRaces = [];

// Fetch everything we need in one query to avoid N+1 issues.
if (!selectedAddressId) {
  const globalDistrictData = await prisma.district.findMany({
    where: {
      deletedAt: null,
      type: DistrictType.ALL,
    },
    include: {
      races: {
        orderBy: { election: { date: "asc" } },
        where: {
          deletedAt: null,
        },
        include: {
          election: true,
          raceType: true,
          candidates: {
            where: { deletedAt: null },
          },
        },
      },
    },
  });
  districtRaces.push(...globalDistrictData.flatMap((d) => d.races ?? []));
} else {
  const voterAddressData = await prisma.voterAddress.findUnique({
    where: { id: selectedAddressId },
    include: {
      districts: {
        include: {
          district: {
            include: {
              races: {
                orderBy: { election: { date: "asc" } },
                where: {
                  deletedAt: null,
                },
                include: {
                  election: true,
                  raceType: true,
                  candidates: {
                    where: { deletedAt: null },
                  },
                },
              },
            },
          },
        },
      },
    },
  });

  if (!voterAddressData) {
    error = "Address not found. Please search for your address again.";
  } else {
    voterAddress = {
      normalizedAddress: voterAddressData.normalizedAddress,
      city: voterAddressData.city,
      zip: voterAddressData.zip,
    };

    // Work with races for the first matched district (preserve existing behavior)
    districtRaces.push(
      ...voterAddressData.districts.flatMap((d) => d.district.races ?? []),
    );
  }
}

// Single pass: validate races, track elections, find best election
const validRaces: typeof districtRaces = [];
const electionMap = new Map<string, (typeof districtRaces)[0]["election"]>();

let closestFutureElection: (typeof districtRaces)[0]["election"] | null = null;
let closestFutureDistance = Infinity;
let mostRecentPastElection: (typeof districtRaces)[0]["election"] | null = null;
let mostRecentPastDistance = -Infinity;

const now = new Date();
const nowTime = now.getTime();

for (const race of districtRaces) {
  if (!race || race.deletedAt || !race.election || race.election.deletedAt) {
    continue;
  }

  validRaces.push(race);
  const electionId = race.election.id;

  // Deduplicate elections via Map (each ID tracked once)
  if (!electionMap.has(electionId)) {
    const election = race.election;

    if (!election.archivedAt) {
      const electionTime = new Date(election.date).getTime();
      const distance = electionTime - nowTime;

      // Track closest future election (smallest positive distance)
      if (distance >= 0 && distance < closestFutureDistance) {
        closestFutureElection = election;
        closestFutureDistance = distance;
      }
      // Track most recent past election (largest negative distance, i.e., closest to now)
      else if (distance < 0 && distance > mostRecentPastDistance) {
        mostRecentPastElection = election;
        mostRecentPastDistance = distance;
      }
    }

    electionMap.set(electionId, election);
  }
}

// Use closest future, fallback to most recent past
const election = closestFutureElection || mostRecentPastElection;

// Filter races to the selected election (O(n) but small n)
const races = election
  ? validRaces
      .filter((r) => r.election && r.election.id === election.id)
      .sort((a, b) => {
        const typeDiff = b.raceType.id - a.raceType.id;
        if (typeDiff !== 0) return typeDiff;
        return a.name.localeCompare(b.name, undefined, {
          numeric: true,
          sensitivity: "base",
        });
      })
  : [];

// Efficiently group into sections for display while maintaining sort order
const raceTypeLabels: Record<number, string> = {
  4: "Federal",
  3: "State",
  2: "County",
  1: "City",
};

interface RaceSection {
  label: string;
  races: typeof races;
}

const raceSections: RaceSection[] = [];
let lastTypeId = -1;

for (const race of races) {
  const typeId = race.raceType.id;
  if (typeId !== lastTypeId) {
    raceSections.push({
      label:
        raceTypeLabels[typeId] || (race.raceType.value as string) || "Other",
      races: [race],
    });
    lastTypeId = typeId;
  } else {
    const lastSection = raceSections[raceSections.length - 1];
    if (lastSection) {
      lastSection.races.push(race);
    }
  }
}

const hasDemocraticPrimary = races.some(
  (r) => r.partyCategory === PartyCategories.DEMOCRATIC,
);
const hasRepublicanPrimary = races.some(
  (r) => r.partyCategory === PartyCategories.REPUBLICAN,
);
const showPrimaryFilters = hasDemocraticPrimary && hasRepublicanPrimary;

const clientRaces = races.map((r) => ({
  id: r.id,
  name: r.name,
  shortName: r.shortName,
  typeLabel:
    raceTypeLabels[r.raceType.id] || (r.raceType.value as string) || "Other",
  candidates: r.candidates.map((c) => ({
    id: c.id,
    name: `${c.firstName}${c.middleName ? " " + c.middleName : ""} ${c.lastName}`,
    party: c.partyAffiliation,
  })),
}));
---

{
  !voterAddress && (
    <div class="mb-12">
      <AddressSearch class="col-span-12 md:col-span-8" />
    </div>
  )
}

<div class="mb-8">
  <h1 class="mb-2 text-4xl font-bold text-gray-900">
    {
      election &&
        `${election.name} (${new Date(election.date).toLocaleDateString()})`
    }
  </h1>
  {
    voterAddress && (
      <p class="text-lg text-gray-600">
        Address:{" "}
        <span class="font-semibold">
          {voterAddress.normalizedAddress}, {voterAddress.city}{" "}
          {voterAddress.zip}
        </span>
        <button
          id="change-address-btn"
          class="text-secondary ml-2 cursor-pointer underline"
        >
          Change Address
        </button>
      </p>
    )
  }
  {
    !voterAddress && (
      <p class="text-lg text-gray-600">
        Elections applicable to all residents of Rutherford County
      </p>
    )
  }
</div>

{
  showPrimaryFilters && (
    <div class="mb-8 flex flex-wrap gap-3" id="primary-filters">
      <button
        class="primary-filter-btn bg-secondary flex-1 rounded-full px-4 py-2 text-sm font-semibold text-white transition-colors hover:opacity-90 md:flex-none"
        data-filter="All"
      >
        All
      </button>
      <button
        class="primary-filter-btn bg-secondary flex-1 rounded-full px-4 py-2 text-sm font-semibold text-white transition-colors hover:opacity-90 md:flex-none"
        data-filter={PartyCategories.DEMOCRATIC}
      >
        Democratic Primary
      </button>
      <button
        class="primary-filter-btn bg-secondary flex-1 rounded-full px-4 py-2 text-sm font-semibold text-white transition-colors hover:opacity-90 md:flex-none"
        data-filter={PartyCategories.REPUBLICAN}
      >
        Republican Primary
      </button>
    </div>
  )
}

{
  error && (
    <div class="mb-8 rounded-lg border border-red-200 bg-red-50 p-4 text-red-700">
      <p>{error}</p>
      <button
        id="error-change-address-btn"
        class="mt-2 inline-block cursor-pointer font-semibold text-red-700 underline hover:text-red-800"
      >
        Search for your address
      </button>
    </div>
  )
}

{
  !error && races.length === 0 && election && (
    <div class="mb-8 rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-yellow-700">
      <p>No races found for this address in the {election.name} election.</p>
    </div>
  )
}

{
  raceSections.length > 0 && election && (
    <div class="space-y-12">
      {raceSections.map((section) => (
        <section>
          <div class="mb-8 flex items-center gap-6">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900">
              {section.label}
            </h2>
            <div class="h-px flex-1 bg-linear-to-r from-gray-200 to-transparent" />
          </div>
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {section.races.map((race) => (
              <VotePlanRace
                race={race}
                election={election}
                candidates={race.candidates}
              />
            ))}
          </div>
        </section>
      ))}

      <div class="mt-20 flex flex-col items-center justify-center pb-20">
        <button
          id="view-summary-btn"
          class="bg-primary hover:bg-primary/90 flex scale-95 cursor-pointer items-center gap-3 rounded-full px-10 py-5 text-xl font-bold text-white shadow-2xl transition-all duration-700 ease-in-out hover:scale-105 active:scale-95"
        >
          <SquareCheckBig size="24" />
          View My Ballot Summary
        </button>
      </div>
    </div>
  )
}

<!-- Summary Modal -->
<dialog
  id="summary-modal"
  class="m-auto h-fit max-h-[90vh] w-[98vw] max-w-4xl overflow-hidden rounded-2xl border-none bg-white p-0 shadow-2xl backdrop:bg-black/50 backdrop:backdrop-blur-sm"
  data-client-races={JSON.stringify(clientRaces)}
  data-logo-src={LogoImg.src}
>
  <div class="flex max-h-[85vh] flex-col">
    <div
      class="bg-primary flex items-center justify-between border-b px-6 py-2 text-white"
    >
      <h2 class="text-2xl font-bold">Your Ballot Summary</h2>
      <div class="flex items-center gap-2">
        <button
          id="share-modal-btn"
          class="hidden cursor-pointer items-center gap-2 rounded-lg bg-white/20 px-3 py-1 text-sm font-semibold transition-colors hover:bg-white/30"
        >
          <Share size="18" />
        </button>
        <!-- <button
          id="close-modal-btn"
          class="cursor-pointer text-white/80 transition-colors hover:text-white"
        >
          <X size="24" />
        </button> -->
      </div>
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-2" id="summary-content">
      <!-- Content populated by JS -->
    </div>

    <div class="flex items-center justify-end border-t bg-gray-50 px-6 py-2">
      <button
        id="close-modal-footer-btn"
        class="bg-primary/10 text-primary hover:bg-primary/20 cursor-pointer rounded-lg px-6 py-2 font-semibold transition-colors"
      >
        Close
      </button>
    </div>
  </div>
</dialog>

{
  !error && !election && (
    <div class="mb-8 rounded-lg border border-blue-200 bg-blue-50 p-4 text-blue-700">
      <p>No elections are currently available.</p>
    </div>
  )
}

<script>
  import * as htmlToImage from "html-to-image";

  interface ClientCandidate {
    id: number;
    name: string;
    party: string | null;
  }

  interface ClientRace {
    id: number;
    name: string;
    shortName: string | null;
    typeLabel: string;
    candidates: ClientCandidate[];
  }

  const summaryModal = document.getElementById("summary-modal");
  const logoSrc = summaryModal?.dataset.logoSrc || "";
  const clientRaces: ClientRace[] = JSON.parse(
    summaryModal ? summaryModal.dataset.clientRaces || "[]" : "[]",
  );

  const clearAddressAndReload = (e: Event) => {
    e.preventDefault();
    // Clear voterAddressId cookie
    document.cookie = "voterAddressId=; max-age=0; path=/";
    // Redirect to home page / ballot page to search again
    window.location.href = "/my-ballot";
  };

  const changeAddressBtn = document.getElementById("change-address-btn");
  if (changeAddressBtn) {
    changeAddressBtn.addEventListener("click", clearAddressAndReload);
  }

  const errorChangeAddressBtn = document.getElementById(
    "error-change-address-btn",
  );
  if (errorChangeAddressBtn) {
    errorChangeAddressBtn.addEventListener("click", clearAddressAndReload);
  }

  // // Scroll visibility for summary button
  const viewSummaryBtn = document.getElementById("view-summary-btn");

  // Modal logic
  const modal = document.getElementById(
    "summary-modal",
  ) as HTMLDialogElement | null;
  const shareBtn = document.getElementById("share-modal-btn");
  const closeModalBtns = [
    document.getElementById("close-modal-btn"),
    document.getElementById("close-modal-footer-btn"),
  ];
  const summaryContent = document.getElementById(
    "summary-content",
  ) as HTMLElement | null;

  if (modal && typeof modal.showModal !== "function") {
    // If showModal is not supported, we can fallback to a simple display: block
    // though modern Safari supports it.
    console.warn("Dialog showModal not supported");
  }

  // Check if sharing is supported (specifically for files)
  const checkShareSupport = async () => {
    if (!navigator.share || !navigator.canShare) return false;

    try {
      // Create a tiny dummy file to test if the browser supports sharing files
      const testFile = new File([" "], "test.txt", { type: "text/plain" });
      return navigator.canShare({ files: [testFile] });
    } catch {
      return false;
    }
  };

  const handleShare = async () => {
    const originalShareCard = document.getElementById("share-card");
    if (!originalShareCard || !shareBtn) return;

    // Ensure the ORIGINAL logo is warm and ready before cloning
    const originalLogo = originalShareCard.querySelector(
      'img[alt="Logo"]',
    ) as HTMLImageElement | null;
    if (originalLogo) {
      if (!originalLogo.complete) {
        await new Promise((r) => {
          originalLogo.onload = r;
          originalLogo.onerror = r;
        });
      }
      try {
        await originalLogo.decode();
      } catch {
        /* ignore */
      }
    }

    // Create a hidden container for the off-screen capture
    const captureStage = document.createElement("div");
    captureStage.style.position = "fixed";
    captureStage.style.left = "-2000px"; // Less aggressive than -9999px for some older engines
    captureStage.style.top = "0";
    captureStage.style.width = "600px";
    captureStage.style.zIndex = "-100";
    captureStage.style.pointerEvents = "none"; // Ensure it doesn't block interactions
    captureStage.style.backgroundColor = "white";
    document.body.appendChild(captureStage);

    // Clone the card and add it to our secret stage
    const shareCard = originalShareCard.cloneNode(true) as HTMLElement;
    captureStage.appendChild(shareCard);

    try {
      // Prepare the secret clone for capture
      shareCard.style.width = "600px";
      shareCard.style.height = "auto";
      shareCard.style.minHeight = "750px";
      shareCard.style.overflow = "visible";
      shareCard.style.display = "flex";

      // Show share-only elements on the clone ONLY
      const shareOnlyElements = shareCard.querySelectorAll(".share-only");
      shareOnlyElements.forEach((el) => el.classList.remove("hidden"));

      // Explicitly wait for the logo to be ready on the clone
      const logoImg = shareCard.querySelector(
        'img[alt="Logo"]',
      ) as HTMLImageElement | null;
      if (logoImg) {
        // Force a re-src to trigger a load/decoded state in the new context
        const currentSrc = logoImg.src;
        logoImg.src = "";
        logoImg.src = currentSrc;

        if (!logoImg.complete) {
          await new Promise((r) => {
            logoImg.onload = r;
            logoImg.onerror = r;
          });
        }
        if (typeof logoImg.decode === "function") {
          try {
            await logoImg.decode();
          } catch {
            /* Decode failed, proceed with capture */
          }
        }
      }

      // Small delay to ensure paint is complete on the secret stage
      await new Promise((r) => setTimeout(r, 400));

      const blob = await htmlToImage.toBlob(shareCard, {
        backgroundColor: "white",
        pixelRatio: 2,
        cacheBust: true, // Force fresh assets in the capture engine
      });

      if (!blob) throw new Error("Could not generate image");

      const file = new File([blob], "ballot-summary.png", {
        type: "image/png",
      });

      if (navigator.canShare && navigator.canShare({ files: [file] })) {
        await navigator.share({
          files: [file],
          title: "My Ballot Summary",
        });
      } else {
        alert("Sharing files is not supported on this browser.");
      }
    } catch (err) {
      console.error("Error sharing:", err);
      alert("Something went wrong while trying to share.");
    } finally {
      // Clean up the secret stage
      document.body.removeChild(captureStage);
    }
  };

  shareBtn?.addEventListener("click", handleShare);

  const STORAGE_KEY = "vote_plan_selections";

  const renderSummary = () => {
    if (!summaryContent) return;

    let selections: Record<string, string[]> = {};
    try {
      const selectionsData = localStorage.getItem(STORAGE_KEY);
      selections = selectionsData ? JSON.parse(selectionsData) : {};
    } catch (e) {
      console.error("Error parsing selections from localStorage:", e);
    }

    const categories: Record<
      string,
      (ClientRace & { selectedCandidates: ClientCandidate[] })[]
    > = {};
    let hasActiveSelection = false;

    for (const race of clientRaces) {
      const id = String(race.id);
      const selectedIds = selections[id] || [];
      if (!selectedIds || selectedIds.length === 0) continue;

      const selectedCandidates = race.candidates.filter((c) =>
        selectedIds.includes(String(c.id)),
      );

      if (selectedCandidates.length > 0) {
        hasActiveSelection = true;
        const typeLabel = race.typeLabel;
        if (!categories[typeLabel]) {
          categories[typeLabel] = [];
        }
        categories[typeLabel]?.push({
          ...race,
          selectedCandidates,
        });
      }
    }

    if (!hasActiveSelection) {
      summaryContent.innerHTML = `
        <div class="py-12 text-center">
          <p class="text-gray-500 text-lg">You haven't made any selections yet.</p>
          <p class="text-gray-400">Close this and select your candidates to see a summary here.</p>
        </div>
      `;
      return false;
    }

    let html = `
      <div id="share-card" class="bg-white p-6 md:p-8 flex flex-col h-fit">
        <!-- Social Share Header (hidden in modal) -->
        <div class="mb-8 flex flex-col items-center hidden share-only">
          <img src="${logoSrc}" class="w-32 mb-3" alt="Logo" />
          <div class="h-0.5 w-64 bg-primary rounded-full mb-4"></div>
          <h3 class="text-xl font-black text-primary tracking-[0.1em] uppercase">My Ballot Plan</h3>
        </div>
        
        <div class="space-y-8 flex-1">
    `;

    // Order categories by the same priority as the main list
    const labelOrder = ["Federal", "State", "County", "City"];
    const sortedCategories = Object.keys(categories).sort((a, b) => {
      const idxA = labelOrder.indexOf(a);
      const idxB = labelOrder.indexOf(b);
      if (idxA !== -1 && idxB !== -1) return idxA - idxB;
      if (idxA !== -1) return -1;
      if (idxB !== -1) return 1;
      return a.localeCompare(b);
    });

    sortedCategories.forEach((label) => {
      const races = categories[label];
      if (!races) return;
      html += `
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="text-[12px] font-black uppercase tracking-[0.25em] text-primary/30 whitespace-nowrap">${label}</span>
            <div class="h-px flex-1 bg-gray-100"></div>
          </div>
          <div class="grid grid-cols-2 gap-x-8 gap-y-4">
            ${races
              .map(
                (race) => `
              <div class="min-w-0">
                <div class="text-[11px] font-bold text-gray-400 uppercase tracking-tight mb-1 truncate" title="${race.name}">${race.shortName || race.name}</div>
                <div class="space-y-2">
                  ${race.selectedCandidates
                    .map(
                      (c) => `
                    <div class="text-[15px] font-bold text-gray-900 flex items-start gap-2.5 leading-snug">
                       <div class="w-2 h-2 rounded-full bg-secondary mt-1.5 shrink-0"></div>
                       <div class="flex flex-col">
                         <span>${c.name}</span>
                         ${c.party ? `<span class="text-[11px] font-medium text-gray-400 uppercase tracking-tighter">(${c.party})</span>` : ""}
                       </div>
                    </div>
                  `,
                    )
                    .join("")}
                </div>
              </div>
            `,
              )
              .join("")}
          </div>
        </div>
      `;
    });

    html += `
        </div>
        
        <!-- Social Share Footer (hidden in modal) -->
        <div class="mt-10 pt-6 border-t border-gray-100 flex flex-col items-center hidden share-only">
          <p class="text-primary/40 font-bold text-[9px] mt-0.5">GOVOTERUTHERFORD.COM</p>
        </div>
      </div>
    `;
    summaryContent.innerHTML = html;
    return true;
  };

  viewSummaryBtn?.addEventListener("click", async () => {
    const hasActiveSelection = renderSummary();
    modal?.showModal();
    document.body.style.overflow = "hidden"; // Prevent background scroll

    // Toggle share button visibility based on support and content
    if (hasActiveSelection && (await checkShareSupport())) {
      shareBtn?.classList.remove("hidden");
      shareBtn?.classList.add("flex");
    } else {
      shareBtn?.classList.add("hidden");
      shareBtn?.classList.remove("flex");
    }
  });

  const closeModal = () => {
    modal?.close();
    document.body.style.overflow = "auto";
  };

  modal?.addEventListener("close", () => {
    document.body.style.overflow = "auto";
  });

  closeModalBtns.forEach((btn) => btn?.addEventListener("click", closeModal));

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
</script>

<style>
  /* Safari specific backdrop filter support */
  dialog::backdrop {
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    background-color: rgba(0, 0, 0, 0.5);
  }

  /* Centering fix for Safari when using showModal() */
  dialog[open] {
    display: flex;
    flex-direction: column;
  }

  /* Some older Safari versions don't handle h-fit well with auto margins */
  @supports not (height: fit-content) {
    dialog {
      height: auto;
    }
  }
</style>

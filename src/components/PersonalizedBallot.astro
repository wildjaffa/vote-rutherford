---
import RaceCard from "./RaceCard.astro";
import prisma from "../lib/prisma";
import { DistrictType } from "../generated/prisma/browser";
import AddressSearch from "./AddressSearch.astro";

// Inside a server island we can access Astro.url and Astro.cookies.
const queryGroupId = Astro.url.searchParams.get("groupId");
const cookieGroupId = Astro.cookies.get("voterDistrictGroupId")?.value;

const selectedGroupId = queryGroupId || cookieGroupId;

let error: string | null = null;

const districtRaces = [];

// Fetch everything we need in one query to avoid N+1 issues.
if (!selectedGroupId) {
  const globalDistrictData = await prisma.district.findMany({
    where: {
      deletedAt: null,
      type: DistrictType.ALL,
    },
    include: {
      races: {
        orderBy: { election: { date: "asc" } },
        where: {
          deletedAt: null,
        },
        include: {
          election: true,
          raceType: true,
          candidates: {
            where: { deletedAt: null },
          },
        },
      },
    },
  });
  districtRaces.push(...globalDistrictData.flatMap((d) => d.races ?? []));
} else {
  const districtGroupData = await prisma.districtGroup.findUnique({
    where: { id: selectedGroupId },
    include: {
      districts: {
        include: {
          district: {
            include: {
              races: {
                orderBy: { election: { date: "asc" } },
                where: {
                  deletedAt: null,
                },
                include: {
                  election: true,
                  raceType: true,
                  candidates: {
                    where: { deletedAt: null },
                  },
                },
              },
            },
          },
        },
      },
    },
  });

  if (!districtGroupData) {
    error = "Address not found. Please search for your address again.";
  } else {
    // Work with races for the given district group
    districtRaces.push(
      ...districtGroupData.districts.flatMap((d) => d.district.races ?? []),
    );
  }
}

// Single pass: validate races, track elections, find best election
const validRaces: typeof districtRaces = [];
const electionMap = new Map<string, (typeof districtRaces)[0]["election"]>();

let closestFutureElection: (typeof districtRaces)[0]["election"] | null = null;
let closestFutureDistance = Infinity;
let mostRecentPastElection: (typeof districtRaces)[0]["election"] | null = null;
let mostRecentPastDistance = -Infinity;

const now = new Date();
const nowTime = now.getTime();

for (const race of districtRaces) {
  if (!race || race.deletedAt || !race.election || race.election.deletedAt) {
    continue;
  }

  validRaces.push(race);
  const electionId = race.election.id;

  // Deduplicate elections via Map (each ID tracked once)
  if (!electionMap.has(electionId)) {
    const election = race.election;

    if (!election.archivedAt) {
      const electionTime = new Date(election.date).getTime();
      const distance = electionTime - nowTime;

      // Track closest future election (smallest positive distance)
      if (distance >= 0 && distance < closestFutureDistance) {
        closestFutureElection = election;
        closestFutureDistance = distance;
      }
      // Track most recent past election (largest negative distance, i.e., closest to now)
      else if (distance < 0 && distance > mostRecentPastDistance) {
        mostRecentPastElection = election;
        mostRecentPastDistance = distance;
      }
    }

    electionMap.set(electionId, election);
  }
}

// Use closest future, fallback to most recent past
const election = closestFutureElection || mostRecentPastElection;

// Filter races to the selected election (O(n) but small n)
const races = election
  ? validRaces
      .filter((r) => r.election && r.election.id === election.id)
      .sort((a, b) => {
        const typeDiff = b.raceType.id - a.raceType.id;
        if (typeDiff !== 0) return typeDiff;
        return a.name.localeCompare(b.name);
      })
  : [];

// Efficiently group into sections for display while maintaining sort order
const raceTypeLabels: Record<number, string> = {
  4: "Federal",
  3: "State",
  2: "County",
  1: "City",
};

interface RaceSection {
  label: string;
  races: typeof races;
}

const raceSections: RaceSection[] = [];
let lastTypeId = -1;

for (const race of races) {
  const typeId = race.raceType.id;
  if (typeId !== lastTypeId) {
    raceSections.push({
      label:
        raceTypeLabels[typeId] || (race.raceType.value as string) || "Other",
      races: [race],
    });
    lastTypeId = typeId;
  } else {
    const lastSection = raceSections[raceSections.length - 1];
    if (lastSection) {
      lastSection.races.push(race);
    }
  }
}
---

{
  !selectedGroupId && (
    <div class="mb-12">
      <AddressSearch class="col-span-12 md:col-span-8" />
    </div>
  )
}

<div class="center mb-6">
  <h1 class="mb-2 text-4xl font-bold text-gray-900">
    {
      election &&
        `${election.name} (${new Date(election.date).toLocaleDateString()})`
    }
  </h1>
  {
    selectedGroupId && (
      <p
        class="text-lg text-gray-600"
        id="address-display-container"
        style="display: none;"
      >
        Address: <span class="font-semibold" id="address-display-text" />
        <button
          id="change-address-btn"
          class="text-secondary ml-2 cursor-pointer underline"
        >
          Change Address
        </button>
      </p>
    )
  }
  {
    !selectedGroupId && (
      <p class="text-lg text-gray-600">
        Elections applicable to all residents of Rutherford County
      </p>
    )
  }
</div>

{
  error && (
    <div class="mb-8 rounded-lg border border-red-200 bg-red-50 p-4 text-red-700">
      <p>{error}</p>
      <button
        id="error-change-address-btn"
        class="mt-2 inline-block cursor-pointer font-semibold text-red-700 underline hover:text-red-800"
      >
        Search for your address
      </button>
    </div>
  )
}

{
  !error && races.length === 0 && election && (
    <div class="mb-8 rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-yellow-700">
      <p>No races found for this address in the {election.name} election.</p>
    </div>
  )
}

{
  raceSections.length > 0 && election && (
    <div class="space-y-12">
      {raceSections.map((section) => (
        <section>
          <div class="mb-6 items-center">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900">
              {section.label}
            </h2>
            <div class="bg-primary h-1 w-full md:w-[32%]" />
          </div>
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {section.races.map((race) => (
              <RaceCard
                race={race}
                election={election}
                candidates={race.candidates}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  )
}

{
  !error && !election && (
    <div class="mb-8 rounded-lg border border-blue-200 bg-blue-50 p-4 text-blue-700">
      <p>No elections are currently available.</p>
    </div>
  )
}

<script>
  const clearAddressAndReload = (e: Event) => {
    e.preventDefault();
    // Clear voterDistrictGroupId cookie
    document.cookie = "voterDistrictGroupId=; max-age=0; path=/";
    localStorage.removeItem("voterAddressDisplay");
    // Redirect to home page / ballot page to search again
    window.location.href = "/my-ballot";
  };

  const addressContainer = document.getElementById("address-display-container");
  const addressText = document.getElementById("address-display-text");
  if (addressContainer && addressText) {
    try {
      const stored = localStorage.getItem("voterAddressDisplay");
      if (stored) {
        const data = JSON.parse(stored);
        const parts = [data.normalizedAddress, data.city, data.zip].filter(
          Boolean,
        );
        addressText.textContent = parts.join(", ");
        addressContainer.style.display = "block";
      }
    } catch (e) {
      console.error("Error loading address from localStorage:", e);
      /* ignore */
    }
  }

  const changeAddressBtn = document.getElementById("change-address-btn");
  if (changeAddressBtn) {
    changeAddressBtn.addEventListener("click", clearAddressAndReload);
  }

  const errorChangeAddressBtn = document.getElementById(
    "error-change-address-btn",
  );
  if (errorChangeAddressBtn) {
    errorChangeAddressBtn.addEventListener("click", clearAddressAndReload);
  }
</script>

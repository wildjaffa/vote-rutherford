---
import { Calendar, Layers, ArrowRight } from "@lucide/astro";
import type { Election, Race } from "../generated/prisma/browser";

interface Props {
  election: Election;
  races: Race[];
}

const { election, races } = Astro.props;

// Formatting the date
const formattedDate = new Date(election.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<div
  class="border border-gray-200 rounded-lg overflow-hidden shadow hover:shadow-lg hover:-translate-y-1 transition-transform bg-white group p-6 transform-gpu flex flex-col h-full"
>
  <div class="mb-4">
    <h3 class="text-xl font-bold text-gray-900 group-hover:text-secondary mb-2">
      {election.name}
    </h3>
    <p class="text-sm text-gray-500 mb-3 flex items-center">
      <Calendar size={16} class="mr-1.5" />
      {formattedDate}
    </p>
    <p class="text-gray-600 line-clamp-3 leading-relaxed">
      {election.description}
    </p>
  </div>

  <div
    class="mt-auto border-t border-gray-100 pt-4 flex justify-between items-center"
  >
    <div class="flex items-center text-sm text-gray-500">
      <Layers size={16} class="mr-1.5" />
      <span class="font-medium"
        >{races.length}
        {races.length === 1 ? "Race" : "Races"}</span
      >
    </div>

    <a
      href={`/elections/${election.slug}`}
      class="text-secondary hover:text-primary font-medium inline-flex items-center text-sm"
    >
      View Races
      <ArrowRight size={16} class="ml-1" />
    </a>
  </div>
</div>

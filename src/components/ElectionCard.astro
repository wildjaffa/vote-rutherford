---
import type { Election, Race } from "../generated/prisma/browser";
import { Calendar, Layers, ArrowRight } from "../lib/icons";

interface Props {
  election: Election;
  races: Race[];
}

const { election, races } = Astro.props;

// Formatting the date
const formattedDate = new Date(election.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<div
  class="group flex h-full transform-gpu flex-col overflow-hidden rounded-lg border border-gray-200 bg-white p-6 shadow transition-transform hover:-translate-y-1 hover:shadow-lg"
>
  <div class="mb-4">
    <h3 class="group-hover:text-secondary mb-2 text-xl font-bold text-gray-900">
      {election.name}
    </h3>
    <p class="mb-3 flex items-center text-sm text-gray-500">
      <Calendar size={16} class="mr-1.5" />
      {formattedDate}
    </p>
    <p class="line-clamp-3 leading-relaxed text-gray-600">
      {election.description}
    </p>
  </div>

  <div
    class="mt-auto flex items-center justify-between border-t border-gray-100 pt-4"
  >
    <div class="flex items-center text-sm text-gray-500">
      <Layers size={16} class="mr-1.5" />
      <span class="font-medium"
        >{races.length}
        {races.length === 1 ? "Race" : "Races"}</span
      >
    </div>

    <a
      href={`/elections/${election.slug}`}
      class="text-secondary hover:text-primary inline-flex items-center text-sm font-medium"
    >
      View Races
      <ArrowRight size={16} class="ml-1" />
    </a>
  </div>
</div>

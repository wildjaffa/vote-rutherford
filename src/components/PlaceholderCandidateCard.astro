---
interface Props {
  sourceRaceName: string;
}

const { sourceRaceName } = Astro.props;
---

<div class="group flex relative h-full transform-gpu flex-col items-center overflow-hidden rounded-lg border border-dashed border-gray-300 bg-gray-50 p-6 text-center transition-transform opacity-75 grayscale sepia-0">
  <div class="mb-4 flex h-32 w-32 shrink-0 items-center justify-center overflow-hidden rounded-full bg-gray-200 ring-4 ring-white shadow-inner">
    <svg class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
  </div>

  <h3 class="m-0 mb-2 text-xl font-bold text-gray-500">
    Pending Winner
  </h3>
  <p class="text-gray-400 text-sm italic">from {sourceRaceName}</p>

  <div class="mt-auto pt-4">
    <span class="inline-flex items-center text-gray-400 font-medium cursor-not-allowed">
      Awaiting Results
    </span>
  </div>
</div>

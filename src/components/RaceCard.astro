---
import { PartyCategories } from "../constants";
import RaceType from "../enums/raceTypeEnum";
import type { Candidate, Election, Race } from "../generated/prisma/browser";
import { ArrowRight, Calendar, Users } from "../lib/icons";

interface Props {
  election: Election;
  race: Race;
  candidates: Candidate[];
}

const { race, election, candidates } = Astro.props;

// Map raceTypeId to race type label
const getRaceTypeLabel = (raceTypeId: number): string => {
  const typeLabels: Record<number, string> = {
    [RaceType.city]: "City",
    [RaceType.county]: "County",
    [RaceType.state]: "State",
    [RaceType.federal]: "Federal",
  };
  return typeLabels[raceTypeId] || "Unknown";
};

const typeLabel = getRaceTypeLabel(race.raceTypeId);
---

<div
  class="group flex h-full transform-gpu flex-col overflow-hidden rounded-lg border border-gray-200 bg-white p-6 shadow transition-transform hover:-translate-y-1 hover:shadow-lg"
>
  <div class="flex-none">
    {
      race.partyCategory && (
        <span
          class={`my-1 mr-2 inline-block rounded-md px-3 py-2 text-xs font-semibold tracking-wide uppercase md:text-sm ${
            race.partyCategory === PartyCategories.DEMOCRATIC
              ? "bg-primary text-white"
              : race.partyCategory === PartyCategories.REPUBLICAN
                ? "bg-tertiary text-white"
                : "bg-accent text-black"
          }`}
        >
          {race.partyCategory}
        </span>
      )
    }
    <span
      class="bg-accent my-1 inline-block rounded-md px-3 py-2 text-xs font-semibold tracking-wide text-black uppercase md:text-sm"
    >
      {typeLabel}
    </span>
  </div>
  <div class="flex flex-1 flex-col pt-4">
    <h3
      class="group-hover:text-secondary m-0 mb-2 text-xl font-bold text-gray-900"
    >
      {race.name}
    </h3>
    <p class="m-0 mb-3 leading-relaxed text-gray-600">{race.description}</p>

    <div class="grow"></div>

    <p class="mb-3">
      <Calendar size="18" stroke-width={2} class="text-secondary mr-1 inline" />
      {
        new Date(election.date).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }<Users size="16" stroke-width={2} class="text-secondary ml-2 inline" />
      {candidates.length} Candidates
      {
        race.numSelections > 1 && (
          <>
            <span class="mx-2">•</span>
            Select up to {race.numSelections}
          </>
        )
      }
    </p>
    <div>
      <a
        href={`/elections/${election.slug}/${race.slug}`}
        class="text-secondary hover:text-primary font-medium"
        >View Candidates<ArrowRight
          size="16"
          stroke-width={2}
          class="ml-1 inline"
        /></a
      >
    </div>
  </div>
</div>

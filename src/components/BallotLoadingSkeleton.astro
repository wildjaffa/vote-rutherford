---

---

<div id="skeleton-container" class="animate-pulse">
  {
    /* Address Search Skeleton - Match the centered grid layout from PersonalizedBallot */
  }
  <div class="mb-12 grid grid-cols-12">
    <div class="col-span-2 hidden md:block"></div>
    <div class="col-span-12 h-14 rounded-full bg-gray-200 md:col-span-8"></div>
    <div class="col-span-2 hidden md:block"></div>
  </div>

  {/* Page Header Skeleton */}
  <div class="mb-10 lg:mb-14">
    <div class="mb-4 h-12 w-full rounded-md bg-gray-200 md:w-4/5 lg:w-2/3">
    </div>
    <div class="h-6 w-3/4 rounded-md bg-gray-200 md:w-1/2 lg:w-2/5"></div>
  </div>

  <div class="space-y-16 lg:space-y-24">
    {
      [1, 2].map(() => (
        <section>
          {/* Section Header */}
          <div class="mb-10 flex items-center gap-6">
            <div class="h-10 w-64 rounded-md bg-gray-200" />
            <div class="h-px flex-1 bg-linear-to-r from-gray-200 to-transparent" />
          </div>

          {/* Cards Grid */}
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            {Array.from({ length: 6 }).map(() => (
              <div class="flex min-h-[250px] flex-col rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                {/* Badges */}
                <div class="mb-3 flex gap-2">
                  <div class="h-6 w-24 rounded bg-gray-100" />
                  <div class="h-6 w-20 rounded bg-gray-100" />
                </div>

                <div class="mb-4 pt-1">
                  <div class="mb-3 h-7 w-full rounded bg-gray-200" />
                  <div class="space-y-2">
                    <div class="h-3 w-full rounded bg-gray-100" />
                    <div class="h-3 w-full rounded bg-gray-100" />
                    <div class="h-3 w-11/12 rounded bg-gray-100" />
                  </div>
                </div>

                {/* More compact interaction area */}
                <div class="mt-2 mb-6 space-y-2">
                  <div class="h-9 w-full rounded border border-gray-50 bg-gray-50/30" />
                  <div class="h-9 w-full rounded border border-gray-50 bg-gray-50/30" />
                </div>

                <div class="mt-auto flex items-center justify-between border-t border-gray-50 pt-3">
                  <div class="h-3 w-32 rounded bg-gray-50" />
                  <div class="h-4 w-24 rounded bg-gray-200" />
                </div>
              </div>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</div>

<style>
  #skeleton-container {
    opacity: 0;
    animation: fadeIn 200ms 250ms forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>

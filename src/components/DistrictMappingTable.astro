---
interface Props {
  mappings: Array<{
    oldDistrictId: string;
    newDistrictId: string;
    type: string;
    name: string;
    number: number | null;
  }>;
}

const { mappings } = Astro.props;
---

<div class="mt-6">
  <h4 class="text-md mb-4 font-medium text-gray-900">District Mappings</h4>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th
            class="px-6 py-3 text-left text-xs font-medium tracking-wider text-gray-500 uppercase"
          >
            Type
          </th>
          <th
            class="px-6 py-3 text-left text-xs font-medium tracking-wider text-gray-500 uppercase"
          >
            Name
          </th>
          <th
            class="px-6 py-3 text-left text-xs font-medium tracking-wider text-gray-500 uppercase"
          >
            Number
          </th>
          <th
            class="px-6 py-3 text-left text-xs font-medium tracking-wider text-gray-500 uppercase"
          >
            Status
          </th>
          <th
            class="px-6 py-3 text-left text-xs font-medium tracking-wider text-gray-500 uppercase"
          >
            Action
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 bg-white">
        {
          mappings.map((mapping) => (
            <tr>
              <td class="px-6 py-4 text-sm font-medium whitespace-nowrap text-gray-900">
                {mapping.type}
              </td>
              <td class="px-6 py-4 text-sm whitespace-nowrap text-gray-500">
                {mapping.name}
              </td>
              <td class="px-6 py-4 text-sm whitespace-nowrap text-gray-500">
                {mapping.number ?? "N/A"}
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                {mapping.oldDistrictId ? (
                  <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">
                    Will Update
                  </span>
                ) : (
                  <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                    New District
                  </span>
                )}
              </td>
              <td class="px-6 py-4 text-sm whitespace-nowrap text-gray-500">
                {mapping.oldDistrictId ? (
                  <button
                    type="button"
                    class="text-sm text-blue-600 hover:text-blue-900"
                    onclick={`editMapping('${mapping.newDistrictId}')`}
                  >
                    Edit
                  </button>
                ) : (
                  <span class="text-gray-400">No action needed</span>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="mt-4 text-sm text-gray-600">
    <p>
      <strong>{mappings.filter((m) => m.oldDistrictId).length}</strong> districts
      will be updated with new boundaries.
      <strong>{mappings.filter((m) => !m.oldDistrictId).length}</strong> new districts
      will be created.
    </p>
  </div>
</div>

<script>
  function editMapping(districtId: string) {
    // TODO: Implement manual mapping override
    console.log("Edit mapping for district:", districtId);
  }
</script>

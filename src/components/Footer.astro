---
import "../styles/global.css";
import { ExternalLink } from "../lib/icons";
---

<footer class="bg-secondary mt-12 text-white shadow-md">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- About Section -->
      <div>
        <h3 class="text-accent mb-4 text-lg font-bold">
          About Vote Rutherford
        </h3>
        <p class="text-sm text-gray-200">
          Empowering voters with clear, accessible information about candidates
          and races in Rutherford County.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-accent mb-4 text-lg font-bold">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/" class="hover:text-accent transition-colors">Home</a>
          </li>
          <li>
            <a href="/elections" class="hover:text-accent transition-colors"
              >Upcoming Elections</a
            >
          </li>
          <li>
            <a href="/about" class="hover:text-accent transition-colors"
              >About</a
            >
          </li>
          <li>
            <a href="/how-it-works" class="hover:text-accent transition-colors"
              >How it Works</a
            >
          </li>
          <li>
            <a
              href="/privacy-policy"
              class="hover:text-accent transition-colors">Privacy Policy</a
            >
          </li>
          <li>
            <a
              href="/terms-of-service"
              class="hover:text-accent transition-colors">Terms of Service</a
            >
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-accent mb-4 text-lg font-bold">Resources</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://rutherfordcountytn.gov/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition-colors"
              >Rutherford County Site<ExternalLink
                class="ml-1 inline align-text-top"
                size="13"
              /></a
            >
          </li>
          <li>
            <a
              href="https://ovr.govote.tn.gov/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition-colors"
              >Register to Vote<ExternalLink
                class="ml-1 inline align-text-top"
                size="13"
              />
            </a>
          </li>
          <li>
            <a
              href="https://sos.tn.gov/govotetn"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition-colors"
              >Tennessee Voter Information<ExternalLink
                class="ml-1 inline align-text-top"
                size="13"
              />
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div
      class="my-8 border-t border-white/20 pt-8 text-center text-sm text-gray-300"
    >
      <p>
        &copy; {new Date().getFullYear()} Vote Rutherford. All rights reserved.
      </p>
      <p>
        <small>
          Candidate information is provided for educational purposes. Verify all
          information before voting.</small
        >
      </p>
    </div>
  </div>

  <style>
    footer {
      margin-top: auto;
    }
  </style>
</footer>

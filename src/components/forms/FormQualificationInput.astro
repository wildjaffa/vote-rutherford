---
import { QualificationTypes } from "../../constants";
import { qualificationTypeToIcon, Plus, Trash2 } from "../../lib/icons";

interface Props {
  qualifications?: {
    id?: string;
    type: string;
    url: string | null;
    displayText: string;
  }[];
}

const { qualifications = [] } = Astro.props;

const availableTypes = Object.values(QualificationTypes);
---

<div id="external-qualifications-container" class="space-y-4">
  <label class="block text-sm font-medium text-gray-700">Qualifications</label>

  <div id="qualifications-list" class="space-y-3">
    {
      qualifications.map((qualification, index) => {
        const Icon =
          qualificationTypeToIcon[qualification.type] ||
          qualificationTypeToIcon[QualificationTypes.OTHER];
        if (!Icon) return null;
        return (
          <div
            class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3"
            data-index={index}
          >
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-gray-200 bg-white text-gray-400">
              <Icon class="size-5" />
            </div>
            <div class="grid flex-1 grid-cols-1 gap-3 md:grid-cols-2">
              <input
                type="hidden"
                name="qualification-id"
                value={qualification.id || ""}
              />
              <input
                type="hidden"
                name="qualification-type"
                value={qualification.type}
              />
              <div class="space-y-1">
                <input
                  type="text"
                  name="qualification-displayText"
                  value={qualification.displayText}
                  placeholder="Description (optional)"
                  class="focus:border-secondary focus:ring-secondary block w-full rounded-md border-gray-300 shadow-sm sm:text-sm"
                />
              </div>
              <div class="space-y-1">
                <input
                  type="url"
                  name="qualification-url"
                  value={qualification.url}
                  placeholder="URL (e.g., https://facebook.com/...)"
                  class="focus:border-secondary focus:ring-secondary block w-full rounded-md border-gray-300 shadow-sm sm:text-sm"
                />
              </div>
            </div>
            <button
              type="button"
              class="remove-qualification-btn text-gray-400 transition-colors hover:text-red-500"
              title="Remove qualification"
            >
              <Trash2 class="size-5" />
            </button>
          </div>
        );
      })
    }
  </div>

  <div class="hidden" id="icon-library">
    {
      Object.keys(qualificationTypeToIcon).map((key) => {
        const Icon = qualificationTypeToIcon[key];
        if (!Icon) return null;
        return (
          <div id={`${key}-icon`} class="icon-container">
            <Icon class="size-5" />
          </div>
        );
      })
    }
  </div>

  <div class="mt-4 flex items-center gap-3">
    <select
      id="new-qualification-type"
      class="focus:border-secondary focus:ring-secondary block rounded-md border-gray-300 shadow-sm sm:text-sm"
    >
      <option value="" disabled selected>Select qualification type...</option>
      {
        availableTypes.map((type) => (
          <option value={type}>
            {type.charAt(0).toUpperCase() + type.slice(1)}
          </option>
        ))
      }
    </select>
    <button
      type="button"
      id="add-qualification-btn"
      class="inline-flex items-center gap-2 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 transition-colors ring-inset hover:bg-gray-50"
    >
      <Plus class="size-4" />
      Add Qualification
    </button>
  </div>
</div>

<template id="qualification-row-template">
  <div
    class="animate-in fade-in slide-in-from-top-2 flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3 duration-200"
  >
    <div
      class="icon-container flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-gray-200 bg-white text-gray-400"
    >
      <!-- Icon will be injected here -->
    </div>
    <div class="grid flex-1 grid-cols-1 gap-3 md:grid-cols-2">
      <input type="hidden" name="qualification-id" value="" />
      <input type="hidden" name="qualification-type" value="" />
      <div class="space-y-1">
        <input
          type="text"
          name="qualification-displayText"
          placeholder="Display Name"
          class="focus:border-secondary focus:ring-secondary block w-full rounded-md border-gray-300 shadow-sm sm:text-sm"
        />
      </div>
      <div class="space-y-1">
        <input
          type="url"
          name="qualification-url"
          placeholder="URL (optional)"
          class="focus:border-secondary focus:ring-secondary block w-full rounded-md border-gray-300 shadow-sm sm:text-sm"
        />
      </div>
    </div>
    <button
      type="button"
      class="remove-qualification-btn text-gray-400 transition-colors hover:text-red-500"
      title="Remove qualification"
    >
      <Trash2 class="size-5" />
    </button>
  </div>
</template>

<script>
  const qualificationsList = document.getElementById("qualifications-list");
  const typeSelect = document.getElementById(
    "new-qualification-type",
  ) as HTMLSelectElement;
  const addBtn = document.getElementById("add-qualification-btn");
  const template = document.getElementById(
    "qualification-row-template",
  ) as HTMLTemplateElement;

  function attachRemoveHandler(btn: HTMLButtonElement) {
    btn.addEventListener("click", () => {
      btn.closest(".flex")?.remove();
    });
  }

  // Initial handlers
  document
    .querySelectorAll(".remove-qualification-btn")
    .forEach((btn) => attachRemoveHandler(btn as HTMLButtonElement));

  addBtn?.addEventListener("click", () => {
    const type = typeSelect.value;
    if (!type) {
      alert("Please select a qualification type first.");
      return;
    }

    const rowFragment = template.content.cloneNode(true) as DocumentFragment;
    const row = rowFragment.firstElementChild as HTMLElement;
    if (!row) return;

    const typeInput = row.querySelector(
      'input[name="qualification-type"]',
    ) as HTMLInputElement;
    typeInput.value = type;

    const iconContainer = row.querySelector(".icon-container");
    const libraryIcon = document.getElementById(`${type}-icon`);
    if (iconContainer && libraryIcon) {
      iconContainer.appendChild(libraryIcon.cloneNode(true));
    }

    const removeBtn = row.querySelector(
      ".remove-qualification-btn",
    ) as HTMLButtonElement;
    attachRemoveHandler(removeBtn);

    qualificationsList?.appendChild(row);
    typeSelect.value = ""; // Reset select
  });
</script>

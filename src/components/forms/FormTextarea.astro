---
interface Props {
  label: string;
  name: string;
  value?: string;
  required?: boolean;
  error?: string;
  placeholder?: string;
  rows?: number;
}

const {
  label,
  name,
  value = "",
  required = false,
  error,
  placeholder,
  rows = 4,
} = Astro.props;
---

<div class="mb-4">
  <label for={name} class="block text-sm font-medium text-gray-700 mb-2">
    {label}
    {required && <span class="text-red-500">*</span>}
  </label>
  <textarea
    id={name}
    name={name}
    required={required}
    placeholder={placeholder}
    rows={rows}
    class:list={[
      "w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent transition-colors resize-y",
      error ? "border-red-500" : "border-gray-300",
    ]}>{value}</textarea
  >
  {error && <p class="mt-1 text-sm text-red-500">{error}</p>}
</div>

---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import { env } from "../lib/utils/environment";
import { Mail, MessageSquare, MapPin } from "../lib/icons";

const contactEmail = env("CONTACT_EMAIL") || "hello@govoterutherford.com";
---

<Layout
  description="Get in touch with the Vote Rutherford team for questions about local elections, candidate information, or how to get involved with our non-partisan mission."
  title="Contact Us - Vote Rutherford Support"
>
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="bg-primary py-16 text-white md:py-24">
      <div class="container mx-auto px-4 text-center">
        <h1 class="sorts-mill-goudy mb-4 text-4xl font-bold md:text-6xl">
          Get in Touch
        </h1>
        <p class="mx-auto max-w-2xl text-xl opacity-90">
          We're here to help you navigate local elections and ensure every voter in Rutherford County has the information they need.
        </p>
      </div>
    </section>

    <div class="container mx-auto max-w-4xl px-4 py-12 md:py-20">
      <div class="text-center mb-16">
        <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
          How to Reach Us
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-gray-700 leading-relaxed">
           Whether you're a voter with a question or a candidate looking to update your profile, we'd love to hear from you.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        <!-- Email Card -->
        <div class="bg-gray-50 border border-gray-100 rounded-4xl p-8 text-center flex flex-col items-center shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-secondary/10 text-secondary rounded-2xl p-4 mb-6">
            <Mail class="h-8 w-8" />
          </div>
          <h3 class="sorts-mill-goudy text-xl font-bold text-gray-900 mb-4">Email Us</h3>
          <p class="text-gray-600 mb-6 flex-1 text-sm">
            For detailed inquiries, data corrections, or media requests.
          </p>
          <a
            href={`mailto:${contactEmail}`}
            class="text-secondary font-bold hover:underline transition-colors break-all"
          >
            {contactEmail}
          </a>
        </div>

        <!-- Social Card -->
        <div class="bg-gray-50 border border-gray-100 rounded-4xl p-8 text-center flex flex-col items-center shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-secondary/10 text-secondary rounded-2xl p-4 mb-6">
            <MessageSquare class="h-8 w-8" />
          </div>
          <h3 class="sorts-mill-goudy text-xl font-bold text-gray-900 mb-4">Social Media</h3>
          <p class="text-gray-600 mb-6 flex-1 text-sm">
            Follow us for the latest project updates and community election news.
          </p>
          <div class="flex flex-col gap-2">
            <a href="https://instagram.com/govoterutherford" target="_blank" rel="noopener noreferrer" class="text-secondary font-bold hover:underline">Instagram</a>
            <a href="https://facebook.com/govoterutherford" target="_blank" rel="noopener noreferrer" class="text-secondary font-bold hover:underline">Facebook</a>
          </div>
        </div>

        <!-- Location Card -->
        <div class="bg-gray-50 border border-gray-100 rounded-4xl p-8 text-center flex flex-col items-center shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-secondary/10 text-secondary rounded-2xl p-4 mb-6">
            <MapPin class="h-8 w-8" />
          </div>
          <h3 class="sorts-mill-goudy text-xl font-bold text-gray-900 mb-4">Location</h3>
          <p class="text-gray-600 mb-6 flex-1 text-sm">
            Based locally in Murfreesboro, TN.
          </p>
          <address class="not-italic font-bold text-gray-900 text-sm">
            Rutherford County, TN
          </address>
        </div>
      </div>

      <!-- FAQ Section Teaser -->
      <section class="bg-accent/5 border-secondary/20 mt-24 rounded-4xl border-2 p-8 md:p-12 text-center">
          <h2 class="sorts-mill-goudy text-primary mb-4 text-3xl font-bold">
            Need Quick Information?
          </h2>
          <p class="mx-auto max-w-2xl text-lg leading-relaxed text-gray-700 mb-10">
            Check out our "How It Works" page for detailed info on address lookups, privacy policies, and how we collect candidate data.
          </p>
          <div class="flex justify-center">
            <Button variant="secondary" size="lg" href="/how-it-works">
              View How It Works
            </Button>
          </div>
      </section>
    </div>
  </main>
</Layout>

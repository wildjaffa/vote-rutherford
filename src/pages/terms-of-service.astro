---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import { env } from "../lib/utils/environment";

const contactEmail = env("CONTACT_EMAIL");
---

<Layout
  description="Read the Terms of Service for Vote Rutherford. Understand our commitment to non-partisan information and your responsibilities when using our local election tools."
  title="Terms of Service & Usage Information"
>
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="bg-primary py-16 text-white md:py-24">
      <div class="container mx-auto px-4 text-center">
        <h1 class="sorts-mill-goudy mb-4 text-4xl font-bold md:text-6xl">
          Terms of Service
        </h1>
        <p class="mx-auto max-w-2xl text-xl opacity-90">
          Last updated: February 23, 2026
        </p>
      </div>
    </section>

    <div class="container mx-auto max-w-4xl px-4 py-12 md:py-20">
      <div class="space-y-16 md:space-y-24">
        <!-- Agreement to Terms & What We Provide -->
        <section class="grid gap-8 md:grid-cols-2 lg:gap-12">
          <div>
            <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
              Agreement to Terms
            </h2>
            <div class="space-y-4 text-lg leading-relaxed text-gray-700">
              <p>
                By accessing or using Vote Rutherford ("the Site"), you agree to
                these Terms of Service. If you don't agree, please don't use the
                Site.
              </p>
            </div>

            <h2
              class="sorts-mill-goudy text-primary mt-12 mb-6 text-3xl font-bold"
            >
              What We Provide
            </h2>
            <div class="space-y-4 text-lg leading-relaxed text-gray-700">
              <p>
                Vote Rutherford provides information about local elections,
                candidates, and their policy positions. We aim to help voters
                make informed decisions by:
              </p>
              <ul class="space-y-4">
                <li class="flex gap-3">
                  <span class="text-accent font-bold">✓</span>
                  <span
                    >Showing which elections are relevant to your address</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-accent font-bold">✓</span>
                  <span
                    >Displaying candidate information and policy positions</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-accent font-bold">✓</span>
                  <span>Allowing you to create a personal vote plan</span>
                </li>
              </ul>
            </div>
          </div>
          <div
            class="bg-accent/10 flex items-center justify-center rounded-3xl p-8"
          >
            <div class="text-accent">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="120"
                height="120"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-file-text"
                ><path
                  d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"
                ></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path
                  d="M10 9H8"></path><path d="M16 13H8"></path><path
                  d="M16 17H8"></path></svg
              >
            </div>
          </div>
        </section>

        <!-- No Warranties -->
        <section class="rounded-4xl bg-gray-50 p-8 md:p-12">
          <div class="mb-10 text-center">
            <h2 class="sorts-mill-goudy text-primary mb-4 text-3xl font-bold">
              No Warranties
            </h2>
            <p class="text-secondary text-xl font-medium">
              We work hard to keep our information accurate and up-to-date, but:
            </p>
          </div>

          <div class="grid gap-8 md:grid-cols-2">
            <div class="rounded-2xl bg-white p-6 shadow-sm">
              <h3 class="mb-2 font-bold text-gray-900">"As Is" Basis</h3>
              <p class="text-gray-600">
                We provide information "as is" without warranties of any kind.
                We don't guarantee accuracy of candidate information, election
                dates, or district boundaries.
              </p>
            </div>
            <div class="rounded-2xl bg-white p-6 shadow-sm">
              <h3 class="mb-2 font-bold text-gray-900">Verify Information</h3>
              <p class="text-gray-600">
                We're not liable for errors that may affect your voting
                decisions. Always verify election information with official
                sources like your county election office.
              </p>
            </div>
          </div>
          <p class="mt-8 text-center text-sm text-gray-500 italic">
            We are not affiliated with any government agency, political party,
            or candidate.
          </p>
        </section>

        <!-- User Conduct -->
        <section class="border-secondary/20 rounded-4xl border-2 p-8 md:p-12">
          <h2 class="sorts-mill-goudy text-primary mb-8 text-3xl font-bold">
            User Conduct
          </h2>
          <p class="mb-6 text-lg text-gray-700">
            You agree not to use the Site for any illegal purpose or attempt to
            interfere with its operation. Specifically, you agree not to:
          </p>
          <div class="grid gap-6 md:grid-cols-2">
            {
              [
                "Scrape, copy, or redistribute content without permission",
                "Submit false or misleading information",
                "Impersonate another person or entity",
                "Interfere with the Site's technical operation",
              ].map((item) => (
                <div class="flex items-center gap-3">
                  <div class="rounded-full bg-red-100 p-1 text-red-600">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-x"
                    >
                      <path d="M18 6 6 18" />
                      <path d="m6 6 12 12" />
                    </svg>
                  </div>
                  <span class="text-lg text-gray-700">{item}</span>
                </div>
              ))
            }
          </div>
        </section>

        <!-- Candidate and Admin Submissions -->
        <section class="grid items-center gap-8 md:grid-cols-2">
          <div
            class="bg-tertiary/10 order-2 flex items-center justify-center rounded-3xl p-8 md:order-1"
          >
            <div class="text-tertiary">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="120"
                height="120"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-user-check"
                ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                ></path><circle cx="9" cy="7" r="4"></circle><polyline
                  points="16 11 18 13 22 9"></polyline></svg
              >
            </div>
          </div>
          <div class="order-1 md:order-2">
            <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
              Candidate and Admin Submissions
            </h2>
            <div class="space-y-4 text-lg leading-relaxed text-gray-700">
              <p>If you submit information as a candidate or administrator:</p>
              <ul class="space-y-4">
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span
                    >You represent that your submissions are accurate to the
                    best of your knowledge</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span>You grant us permission to display the information</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span
                    >We may moderate or remove content at our discretion</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span
                    >You're responsible for keeping your information current</span
                  >
                </li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Intellectual Property & Third-Party Content -->
        <section
          class="bg-accent/5 border-accent/20 rounded-4xl border-2 p-8 md:p-12"
        >
          <div class="grid items-center gap-8 md:grid-cols-2 lg:gap-12">
            <div>
              <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
                Intellectual Property
              </h2>
              <div class="space-y-6 text-lg leading-relaxed text-gray-700">
                <p>
                  The Site's design, code, and original content are owned by
                  VoteRutherford. Candidate information and policy positions are
                  provided by candidates or sourced from public records.
                </p>
                <div class="rounded-2xl bg-white/50 p-6">
                  <h3 class="text-primary mb-2 font-bold">Usage Rights</h3>
                  <p class="text-base">
                    You may view and use the Site for personal, non-commercial
                    purposes. You may not reproduce or redistribute significant
                    portions of the Site without permission.
                  </p>
                </div>
              </div>
            </div>
            <div>
              <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
                Third-Party Content
              </h2>
              <div class="space-y-4 text-lg leading-relaxed text-gray-700">
                <p>We may display information from:</p>
                <ul class="space-y-2">
                  <li class="flex gap-3 text-base">
                    <span class="text-accent font-bold">•</span>
                    <span>Official government sources</span>
                  </li>
                  <li class="flex gap-3 text-base">
                    <span class="text-accent font-bold">•</span>
                    <span>Candidate submissions</span>
                  </li>
                  <li class="flex gap-3 text-base">
                    <span class="text-accent font-bold">•</span>
                    <span>Public records and news sources</span>
                  </li>
                </ul>
                <p class="border-accent/10 mt-4 border-t pt-4 text-base italic">
                  We don't endorse any candidate or political position.
                  Inclusion on the Site doesn't constitute endorsement.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Privacy & Limitation of Liability -->
        <section class="grid gap-12 md:grid-cols-2">
          <div>
            <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
              Privacy
            </h2>
            <div class="space-y-4 text-lg leading-relaxed text-gray-700">
              <p>
                Your use of the Site is also governed by our <a
                  href="/privacy-policy"
                  class="text-primary hover:underline">Privacy Policy</a
                >. Key points:
              </p>
              <ul class="space-y-2 text-base">
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span>We use cookies to remember your address</span>
                </li>
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span>Your vote plan stays on your device</span>
                </li>
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span>We don't track or sell your personal information</span>
                </li>
              </ul>
            </div>
          </div>
          <div>
            <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
              Limitation of Liability
            </h2>
            <div class="space-y-4 text-lg leading-relaxed text-gray-700">
              <p>To the maximum extent permitted by law:</p>
              <ul class="space-y-2 text-base">
                <li class="flex gap-3">
                  <span class="font-bold text-red-500">!</span>
                  <span>We're not liable for any damages arising from use</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-bold text-red-500">!</span>
                  <span
                    >This includes missed elections or incorrect information</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="font-bold text-red-500">!</span>
                  <span>Your use is at your own risk</span>
                </li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Changes, Termination & Law -->
        <section class="rounded-4xl bg-gray-900 p-8 text-white md:p-12">
          <div class="grid gap-12 md:grid-cols-3">
            <div>
              <h3 class="mb-4 text-xl font-bold text-gray-300">
                Changes to Terms
              </h3>
              <p class="text-sm opacity-80">
                We may update these Terms from time to time. Continuing to use
                the Site after changes means you accept the new Terms.
              </p>
            </div>
            <div>
              <h3 class="mb-4 text-xl font-bold text-gray-300">Termination</h3>
              <p class="text-sm opacity-80">
                We reserve the right to suspend access for violations or
                discontinue the Site at any time.
              </p>
            </div>
            <div>
              <h3 class="mb-4 text-xl font-bold text-gray-300">
                Governing Law
              </h3>
              <p class="text-sm opacity-80">
                These Terms are governed by the laws of Tennessee, without
                regard to conflict of law principles.
              </p>
            </div>
          </div>
        </section>

        <!-- Disclaimer of Political Affiliation -->
        <section class="text-center">
          <div
            class="border-secondary/20 mx-auto max-w-3xl rounded-4xl border-2 p-8 md:p-12"
          >
            <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
              Disclaimer of Political Affiliation
            </h2>
            <p class="mb-8 text-lg leading-relaxed text-gray-700">
              Vote Rutherford is a non-partisan information resource. We do not
              endorse any candidate, party, or political position, nor do we
              accept payment for favorable coverage. Our goal is to provide
              accurate, unbiased information to help voters make informed
              decisions.
            </p>
            <div class="flex justify-center gap-4">
              <span class="text-secondary text-2xl">★</span>
              <span class="text-secondary text-2xl">★</span>
              <span class="text-secondary text-2xl">★</span>
            </div>
          </div>
        </section>

        <!-- Contact & Final Note -->
        <section class="text-center">
          <div class="mx-auto max-w-2xl rounded-3xl bg-gray-50 p-8 md:p-12">
            <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
              Contact Us
            </h2>
            <p class="mb-8 text-lg text-gray-700">
              Questions about these Terms? Email us at <a
                href={`mailto:${contactEmail}`}
                class="text-primary hover:underline">{contactEmail}</a
              >.
            </p>

            <div class="mb-8 h-px w-full bg-gray-200"></div>

            <div class="mb-8 space-y-2 text-sm text-gray-500">
              <p>
                If any part of these Terms is found unenforceable, the rest
                remains in effect.
              </p>
              <p>
                These Terms and our Privacy Policy constitute the entire
                agreement between you and Vote Rutherford regarding use of the
                Site.
              </p>
            </div>

            <Button href="/" size="lg">Back to Home</Button>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>

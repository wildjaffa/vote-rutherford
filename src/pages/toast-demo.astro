---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Toast Demo">
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    <h1 class="text-4xl font-bold mb-8">Toast Notification Demo</h1>

    <div class="space-y-6">
      <!-- Demo Controls -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-2xl font-semibold mb-4">Try the Toast Service</h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <button
            id="success-btn"
            class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition-colors"
          >
            Success Toast
          </button>

          <button
            id="error-btn"
            class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition-colors"
          >
            Error Toast
          </button>

          <button
            id="warning-btn"
            class="px-4 py-2 bg-yellow-600 text-white rounded hover:bg-yellow-700 transition-colors"
          >
            Warning Toast
          </button>

          <button
            id="info-btn"
            class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors"
          >
            Info Toast
          </button>
        </div>

        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
          <button
            id="persistent-btn"
            class="px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700 transition-colors"
          >
            Persistent Toast
          </button>

          <button
            id="dismiss-all-btn"
            class="px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700 transition-colors"
          >
            Dismiss All
          </button>
        </div>
      </div>

      <!-- Code Examples -->
      <div class="bg-gray-50 rounded-lg shadow p-6">
        <h2 class="text-2xl font-semibold mb-4">Usage Examples</h2>

        <div class="space-y-4">
          <div>
            <h3 class="font-semibold mb-2">Success Toast</h3>
            <pre
              class="bg-gray-800 text-green-400 p-4 rounded overflow-x-auto"><code>window.toast.success('Operation completed successfully!');</code></pre>
          </div>

          <div>
            <h3 class="font-semibold mb-2">Error Toast</h3>
            <pre
              class="bg-gray-800 text-red-400 p-4 rounded overflow-x-auto"><code>window.toast.error('Something went wrong!');</code></pre>
          </div>

          <!-- <div>
            <h3 class="font-semibold mb-2">Custom Duration</h3>
            <pre class="bg-gray-800 text-blue-400 p-4 rounded overflow-x-auto"><code>window.toast.info('Processing...', { duration: 0 }); // Won't auto-dismiss</code></pre>
          </div> -->

          <div>
            <h3 class="font-semibold mb-2">From TypeScript Modules</h3>
            <pre
              class="bg-gray-800 text-purple-400 p-4 rounded overflow-x-auto"><code>import toast from '../lib/toast';
toast.warning('Please review your input');</code></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Success toast
  document.getElementById("success-btn")?.addEventListener("click", () => {
    window.toast.success("Operation completed successfully!");
  });

  // Error toast
  document.getElementById("error-btn")?.addEventListener("click", () => {
    window.toast.error("Something went wrong!");
  });

  // Warning toast
  document.getElementById("warning-btn")?.addEventListener("click", () => {
    window.toast.warning("Please review your input");
  });

  // Info toast
  document.getElementById("info-btn")?.addEventListener("click", () => {
    window.toast.info("Here is some information");
  });

  // Persistent toast
  document.getElementById("persistent-btn")?.addEventListener("click", () => {
    window.toast.info("This toast will not auto-dismiss", {
      duration: 0,
      dismissible: true,
    });
  });

  // Dismiss all toasts
  document.getElementById("dismiss-all-btn")?.addEventListener("click", () => {
    window.toast.dismissAll();
  });

  // Show a welcome toast when the page loads
  window.toast.info(
    "Welcome to the Toast Demo! Click the buttons to see different toast types.",
  );
</script>

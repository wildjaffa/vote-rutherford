---
import Button from "../components/Button.astro";
import Layout from "../layouts/Layout.astro";
import { env } from "../lib/utils/environment";

const contactEmail = env("CONTACT_EMAIL");
---

<Layout title="How It Works - Vote Rutherford">
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="bg-primary py-16 text-white md:py-24">
      <div class="container mx-auto px-4 text-center">
        <h1 class="sorts-mill-goudy mb-4 text-4xl font-bold md:text-6xl">
          How Address Lookup Works
        </h1>
        <p class="mx-auto max-w-2xl text-xl opacity-90">
          Cutting through the confusion of local elections to bring you clear,
          personalized information.
        </p>
      </div>
    </section>

    <div class="container mx-auto max-w-4xl px-4 py-12 md:py-20">
      <div class="space-y-16 md:space-y-24">
        <!-- Why enter your address? -->
        <section class="grid gap-8 md:grid-cols-2 lg:gap-12">
          <div>
            <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
              Why enter your address?
            </h2>
            <div class="space-y-4 text-lg leading-relaxed text-gray-700">
              <p>
                Local elections can be confusing. Depending on where you live,
                you might vote for city council members, school board trustees,
                county commissioners, state representatives, and more—all in the
                same election.
              </p>
              <p>
                Different streets, sometimes even different apartment buildings,
                can be in completely different districts.
              </p>
              <p>
                We built this tool to cut through the confusion. Enter your
                address, and we'll show you exactly which elections you can vote
                in and which candidates are running to represent you.
              </p>
            </div>
          </div>
          <div
            class="bg-accent/10 flex items-center justify-center rounded-3xl p-8"
          >
            <div class="text-accent text-9xl">
              <span class="sorts-mill-goudy font-bold">?</span>
            </div>
          </div>
        </section>

        <!-- Your privacy matters -->
        <section class="rounded-4xl bg-gray-50 p-8 md:p-12">
          <div class="mb-10 text-center">
            <h2 class="sorts-mill-goudy text-primary mb-4 text-3xl font-bold">
              Your privacy matters
            </h2>
            <p class="text-secondary text-xl font-medium">
              We respect your privacy.
            </p>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            <div class="flex gap-4">
              <div
                class="bg-secondary/10 text-secondary flex h-12 w-12 shrink-0 items-center justify-center rounded-full"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                  ></path><circle cx="12" cy="10" r="3"></circle></svg
                >
              </div>
              <div>
                <h3 class="font-bold text-gray-900">District Matching</h3>
                <p class="text-gray-600">
                  We match your address against our database to find your
                  specific districts.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div
                class="bg-secondary/10 text-secondary flex h-12 w-12 shrink-0 items-center justify-center rounded-full"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                  ></path><circle cx="9" cy="7" r="4"></circle><path
                    d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                    d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
                >
              </div>
              <div>
                <h3 class="font-bold text-gray-900">Personalized Ballot</h3>
                <p class="text-gray-600">
                  We show you only the elections and candidates that will appear
                  on your ballot.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div
                class="bg-secondary/10 text-secondary flex h-12 w-12 shrink-0 items-center justify-center rounded-full"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M21 8.5V10c0 7-9 12-9 12s-9-5-9-12V8.5C3 4.9 6.1 2 10 2c3.9 0 7 2.9 7 6.5Z"
                  ></path><path
                    d="M12 22s9-5 9-12V8.5c0-3.6-3.1-6.5-7-6.5-3.9 0-7 2.9-7 6.5V10c0 7 9 12 9 12Z"
                  ></path></svg
                >
              </div>
              <div>
                <h3 class="font-bold text-gray-900">Local Storage</h3>
                <p class="text-gray-600">
                  We save your address in a cookie on your device so you don't
                  have to re-enter it.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div
                class="bg-secondary/10 text-secondary flex h-12 w-12 shrink-0 items-center justify-center rounded-full"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><rect width="18" height="11" x="3" y="11" rx="2" ry="2"
                  ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
                >
              </div>
              <div>
                <h3 class="font-bold text-gray-900">No Tracking</h3>
                <p class="text-gray-600">
                  We don't track your browsing, log your searches, or share your
                  data with anyone.
                </p>
              </div>
            </div>
          </div>

          <div
            class="mt-10 border-t border-gray-200 pt-8 text-center text-gray-600"
          >
            <p>
              The cookie stays on your device and is only used to remember your
              address for future visits. You can clear it anytime by clearing
              your browser cookies, and we never send your address to third
              parties or use it for any purpose other than showing you your
              elections.
            </p>
          </div>
        </section>

        <!-- Vote Plan Privacy -->
        <section class="border-accent/20 rounded-4xl border-2 p-8 md:p-12">
          <div class="grid gap-8 md:grid-cols-2 lg:gap-12">
            <div class="order-2 md:order-1">
              <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
                Vote Plan Privacy
              </h2>
              <div class="space-y-6 text-lg leading-relaxed text-gray-700">
                <p>
                  When you create a vote plan by selecting your preferred
                  candidates:
                </p>
                <ul class="space-y-4">
                  <li class="flex gap-3">
                    <span class="text-accent font-bold">✓</span>
                    <span
                      ><strong>It never leaves your device.</strong> Your selections
                      are saved in your browser's local storage.</span
                    >
                  </li>
                  <li class="flex gap-3">
                    <span class="text-accent font-bold">✓</span>
                    <span
                      ><strong>We can't see it.</strong> Not in our database, not
                      in our logs, nowhere. It's yours alone.</span
                    >
                  </li>
                  <li class="flex gap-3">
                    <span class="text-accent font-bold">✓</span>
                    <span
                      ><strong>It doesn't sync.</strong> If you create a vote plan
                      on your phone, it won't appear on your laptop.</span
                    >
                  </li>
                  <li class="flex gap-3">
                    <span class="text-accent font-bold">✓</span>
                    <span
                      ><strong>You control it.</strong> Delete it anytime by clearing
                      your browser data.</span
                    >
                  </li>
                </ul>
                <p class="bg-accent/5 rounded-xl p-4 italic">
                  Think of it like writing notes on paper—except the paper only
                  exists on your device.
                </p>
              </div>
            </div>
            <div
              class="bg-accent/10 order-1 flex items-center justify-center rounded-3xl p-8 md:order-2"
            >
              <div class="text-accent">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="120"
                  height="120"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-notebook-pen"
                  ><path
                    d="M11 2H9a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2"
                  ></path><path d="m16 10 4-4"></path><path d="m17 7 3 3"
                  ></path><path d="M7 22H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h3"
                  ></path><path
                    d="M22 10v4.4a2 2 0 0 1-2 2H12a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h5a2 2 0 0 1 2 2Z"
                  ></path></svg
                >
              </div>
            </div>
          </div>
        </section>

        <!-- How we built it -->
        <section>
          <h2
            class="sorts-mill-goudy text-primary mb-10 text-center text-3xl font-bold"
          >
            How we built it
          </h2>
          <div class="grid gap-8 md:grid-cols-3">
            <div class="bg-white p-6 text-center">
              <div
                class="bg-tertiary/10 text-tertiary mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl"
              >
                <span class="text-2xl font-bold">1</span>
              </div>
              <h3 class="mb-3 font-bold text-gray-900">Official Data</h3>
              <p class="text-gray-600">
                We used NG-911 address data and official election district
                boundary files from state and local governments.
              </p>
            </div>

            <div class="bg-white p-6 text-center">
              <div
                class="bg-tertiary/10 text-tertiary mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl"
              >
                <span class="text-2xl font-bold">2</span>
              </div>
              <h3 class="mb-3 font-bold text-gray-900">Pre-calculated</h3>
              <p class="text-gray-600">
                For every address, we determined which districts it belongs to.
                This one-time calculation means your lookup is instant.
              </p>
            </div>

            <div class="bg-white p-6 text-center">
              <div
                class="bg-tertiary/10 text-tertiary mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl"
              >
                <span class="text-2xl font-bold">3</span>
              </div>
              <h3 class="mb-3 font-bold text-gray-900">Keep it Current</h3>
              <p class="text-gray-600">
                We update our database as districts change and add new elections
                and candidates as they're announced.
              </p>
            </div>
          </div>
        </section>

        <!-- How accurate is it? -->
        <section class="border-secondary/20 rounded-4xl border-2 p-8 md:p-12">
          <div class="mb-8">
            <h2 class="sorts-mill-goudy text-primary text-3xl font-bold">
              How accurate is it?
            </h2>
          </div>
          <div class="grid gap-8 md:grid-cols-2">
            <div class="space-y-6">
              <p class="text-lg text-gray-700">
                Our data is as accurate as the official sources we draw from.
                However:
              </p>
              <ul class="space-y-4">
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span
                    ><strong>Apartment buildings:</strong> In rare cases, large complexes
                    span district boundaries. For most accurate results, include your
                    unit number.</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span
                    ><strong>New developments:</strong> Very recently built addresses
                    may not be in our database yet.</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-secondary font-bold">•</span>
                  <span
                    ><strong>Redistricting:</strong> Boundaries change periodically.
                    We update our data as soon as maps are finalized.</span
                  >
                </li>
              </ul>
            </div>
            <div
              class="bg-secondary/5 flex flex-col justify-center rounded-2xl p-6"
            >
              <h4 class="mb-2 font-bold text-gray-900">
                Find something wrong?
              </h4>
              <p class="mb-4 text-gray-600">
                If something looks wrong, please let us know—we're committed to
                keeping this information accurate and helpful.
              </p>
              <a
                href={`mailto:${contactEmail}`}
                class="text-secondary font-semibold hover:underline"
              >
                Contact our team →
              </a>
            </div>
          </div>
        </section>

        <!-- Why this matters -->
        <section class="text-center">
          <div class="mx-auto max-w-2xl">
            <h2 class="sorts-mill-goudy text-primary mb-6 text-3xl font-bold">
              Why this matters
            </h2>
            <p class="text-xl leading-relaxed font-medium text-gray-800">
              Informed voters make democracy work.
            </p>
            <p class="mt-4 text-lg text-gray-600">
              By making it easy to find your local candidates and their
              positions on issues you care about, we hope to help you cast a
              more informed vote in every election—not just the ones that make
              headlines.
            </p>
            <div class="mt-10">
              <Button size="lg" href="/">Find My Ballot</Button>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Optional: Add smooth scrolling if needed */
  html {
    scroll-behavior: smooth;
  }
</style>

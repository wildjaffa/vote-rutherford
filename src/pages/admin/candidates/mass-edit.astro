---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import prisma from "../../../lib/prisma";
import type { Election } from "../../../generated/prisma/browser";

import { Prisma } from "../../../generated/prisma/browser";

export const prerender = false;

interface CandidateEdit {
  id: string;
  firstName: string;
  lastName: string;
  email: string;
  partyAffiliation: string;
  raceName: string;
  raceType: string;
  slug: string;
}

type CandidateWithRace = Prisma.CandidateGetPayload<{
  include: {
    race: {
      include: {
        raceType: true;
      }
    }
  }
}>;

// Fetch all elections for the dropdown
const elections = await prisma.election.findMany({
  orderBy: { date: "desc" },
});

// Determine selected election
const url = new URL(Astro.request.url);
const selectedElectionId = url.searchParams.get("electionId") || (elections.length > 0 ? elections[0]?.id : null);

let candidates: CandidateEdit[] = [];
let error: string | null = null;

if (selectedElectionId) {
  try {
    const rawCandidates = (await prisma.candidate.findMany({
      where: {
        race: {
          electionId: selectedElectionId,
        },
        deletedAt: null,
      },
      include: {
        race: {
          include: {
            raceType: true,
          }
        }
      },
      orderBy: [
        { race: { name: 'asc' } },
        { lastName: 'asc' }
      ]
    })) as CandidateWithRace[];
    
    // Map to a flatter structure for the alpine.js / JS client
    candidates = rawCandidates.map(c => ({
      id: c.id,
      firstName: c.firstName,
      lastName: c.lastName,
      email: c.email || '',
      partyAffiliation: c.partyAffiliation || '',
      raceName: c.race.name,
      raceType: c.race.raceType.value,
      slug: c.slug
    }));
  } catch (err) {
    error = "Failed to load candidates";
    console.error(err);
  }
}

// Extract unique race types and parties for filters
const raceTypes = [...new Set(candidates.map(c => c.raceType))].sort();
const parties = [...new Set(candidates.map(c => c.partyAffiliation))].filter(Boolean).sort();
---

<AdminLayout title="Mass Edit Candidates">
  <div class="space-y-6">
    <!-- Header & Election Selector -->
    <div class="flex items-center justify-between border-b pb-4">
      <div>
        <h2 class="text-xl font-bold text-gray-900">Select Election</h2>
        <p class="text-sm text-gray-500">Choose an election to edit its candidates in bulk.</p>
      </div>
      <div>
        <form method="GET" class="flex items-center gap-3">
          <select 
            name="electionId"
            class="rounded-md border-gray-300 py-2 pl-3 pr-10 text-base focus:border-secondary focus:outline-none focus:ring-secondary sm:text-sm"
            onchange="this.form.submit()"
          >
            {elections.map((election: Election) => (
              <option value={election.id} selected={election.id === selectedElectionId}>
                {election.name} ({new Date(election.date).toLocaleDateString()})
              </option>
            ))}
          </select>
        </form>
      </div>
    </div>

    {error && (
      <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <p class="text-sm font-medium text-red-800">{error}</p>
      </div>
    )}

    {selectedElectionId && candidates.length > 0 && (
      <div class="space-y-4">
        <!-- Filters -->
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 bg-gray-50 p-4 rounded-lg border border-gray-200" id="filter-container">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Search Name</label>
            <input type="text" id="searchName" placeholder="Search by name..." class="block w-full rounded-md border-gray-300 shadow-sm focus:border-secondary focus:ring-secondary sm:text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Filter by Race Type</label>
            <select id="filterRaceType" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-secondary focus:ring-secondary sm:text-sm">
              <option value="">All Types</option>
              {raceTypes.map(type => (
                <option value={type}>{type}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Filter by Party</label>
            <select id="filterParty" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-secondary focus:ring-secondary sm:text-sm">
              <option value="">All Parties</option>
              {parties.map(party => (
                <option value={party}>{party}</option>
              ))}
            </select>
          </div>
        </div>

        <!-- Inline editing table -->
        <div class="overflow-hidden rounded-lg border border-gray-200 shadow">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Candidate Name</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Race</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Party</th>
                <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                <th scope="col" class="px-3 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              </tr>
            </thead>
            <tbody id="candidates-tbody" class="bg-white divide-y divide-gray-200">
              {candidates.map(candidate => (
                <tr class="candidate-row hover:bg-gray-50" data-id={candidate.id} data-racetype={candidate.raceType}>
                  <td class="px-3 py-2 whitespace-nowrap">
                    <div class="flex gap-2">
                       <input 
                         type="text" 
                         name="firstName" 
                         value={candidate.firstName} 
                         class="candidate-input block w-full rounded-md border-transparent hover:border-gray-300 focus:border-secondary focus:ring-secondary sm:text-sm px-2 py-1 transition-colors bg-transparent hover:bg-white focus:bg-white"
                       />
                       <input 
                         type="text" 
                         name="lastName" 
                         value={candidate.lastName} 
                         class="candidate-input block w-full rounded-md border-transparent hover:border-gray-300 focus:border-secondary focus:ring-secondary sm:text-sm px-2 py-1 transition-colors bg-transparent hover:bg-white focus:bg-white"
                       />
                    </div>
                  </td>
                  <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-500">
                    {candidate.raceName}
                  </td>
                  <td class="px-3 py-2 whitespace-nowrap">
                    <input 
                      type="text" 
                      name="partyAffiliation" 
                      value={candidate.partyAffiliation} 
                      class="candidate-input block w-full rounded-md border-transparent hover:border-gray-300 focus:border-secondary focus:ring-secondary sm:text-sm px-2 py-1 transition-colors bg-transparent hover:bg-white focus:bg-white party-search"
                    />
                  </td>
                  <td class="px-3 py-2 whitespace-nowrap">
                    <input 
                      type="email" 
                      name="email" 
                      value={candidate.email} 
                      placeholder="Add email..."
                      class="candidate-input block w-full rounded-md border-transparent hover:border-gray-300 focus:border-secondary focus:ring-secondary sm:text-sm px-2 py-1 transition-colors bg-transparent hover:bg-white focus:bg-white"
                    />
                  </td>
                  <td class="px-3 py-2 whitespace-nowrap text-center text-sm status-cell">
                    <span class="text-gray-400">—</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    {selectedElectionId && candidates.length === 0 && !error && (
      <div class="rounded-lg border border-gray-200 bg-gray-50 p-8 text-center text-gray-500">
        No candidates found for this election.
      </div>
    )}
  </div>

  <script>
    import { actions } from "astro:actions";
    
    // Setup Filtering
    const searchNameInput = document.getElementById("searchName") as HTMLInputElement;
    const filterRaceTypeInput = document.getElementById("filterRaceType") as HTMLSelectElement;
    const filterPartyInput = document.getElementById("filterParty") as HTMLSelectElement;
    const tbody = document.getElementById("candidates-tbody");

    function applyFilters() {
      if (!tbody) return;
      
      const search = searchNameInput?.value.toLowerCase() || "";
      const raceType = filterRaceTypeInput?.value || "";
      const party = filterPartyInput?.value || "";

      Array.from(tbody.querySelectorAll("tr.candidate-row")).forEach((tr) => {
        const row = tr as HTMLElement;
        const firstName = (row.querySelector('input[name="firstName"]') as HTMLInputElement).value.toLowerCase();
        const lastName = (row.querySelector('input[name="lastName"]') as HTMLInputElement).value.toLowerCase();
        const fullName = `${firstName} ${lastName}`;
        const rowRaceType = row.dataset.racetype || "";
        const rowParty = (row.querySelector('input[name="partyAffiliation"]') as HTMLInputElement).value || "";

        const matchSearch = search === "" || fullName.includes(search);
        const matchRaceType = raceType === "" || rowRaceType === raceType;
        const matchParty = party === "" || rowParty === party;

        if (matchSearch && matchRaceType && matchParty) {
          row.style.display = "";
        } else {
          row.style.display = "none";
        }
      });
    }

    searchNameInput?.addEventListener("input", applyFilters);
    filterRaceTypeInput?.addEventListener("change", applyFilters);
    filterPartyInput?.addEventListener("change", applyFilters);


    // Setup Inline Edits
    const inputs = document.querySelectorAll(".candidate-input");
    
    inputs.forEach((inputEl) => {
      const input = inputEl as HTMLInputElement;
      
      // Store original value to detect actual changes
      let originalValue = input.value;
      
      input.addEventListener("focus", () => {
        originalValue = input.value;
      });

      input.addEventListener("blur", async () => {
        if (input.value === originalValue) return; // No change
        
        const row = input.closest("tr");
        if (!row) return;
        
        const id = row.dataset.id;
        const name = input.name;
        const value = input.value;
        const statusCell = row.querySelector(".status-cell") as HTMLElement;

        if (!id) return;

        // Show saving state
        statusCell.innerHTML = '<span class="text-blue-500 animate-pulse">Saving...</span>';

        try {
          // Prepare payload
          const payload = {
            id,
            [name]: value
          };

          const { error } = await actions.partialUpdateCandidate(payload);

          if (error) {
            console.error("Update error:", error);
            // Revert value
            input.value = originalValue;
            window.toast.error(error.message || "Failed to save changes");
            statusCell.innerHTML = '<span class="text-red-500 text-xs font-medium">Error</span>';
            
            // clear status after 3s
            setTimeout(() => {
              if (statusCell.textContent?.includes('Error')) {
                statusCell.innerHTML = '<span class="text-gray-400">—</span>';
              }
            }, 3000);
          } else {
            // Update original value on success
            originalValue = value;
            statusCell.innerHTML = '<span class="text-green-500 text-xs font-bold">Saved</span>';
            
            // clear status after 3s
            setTimeout(() => {
              if (statusCell.textContent?.includes('Saved')) {
                statusCell.innerHTML = '<span class="text-gray-400">—</span>';
              }
            }, 3000);
            
            // If party was changed, we might need to re-apply filter to update visibility or list of parties
            if (name === "partyAffiliation" && filterPartyInput?.value !== "") {
              applyFilters();
            }
          }
        } catch (err) {
          console.error("Exception:", err);
          input.value = originalValue;
          window.toast.error("Network or unexpected error while saving.");
          statusCell.innerHTML = '<span class="text-red-500 text-xs font-medium">Failed</span>';
          setTimeout(() => {
            if (statusCell.textContent?.includes('Failed')) {
              statusCell.innerHTML = '<span class="text-gray-400">—</span>';
            }
          }, 3000);
        }
      });
    });
  </script>
</AdminLayout>

---
import AdminLayout from "../../../../../layouts/AdminLayout.astro";
import prisma from "../../../../../lib/prisma";
import type { RaceWithCandidates } from "../../../../../lib/types";
import { Plus, GripVertical } from "../../../../../lib/icons";

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/admin/elections");
}

const election = await prisma.election.findUnique({
  where: { slug },
  include: {
    races: {
      where: {
        deletedAt: null,
      },
      include: {
        candidates: {
          where: {
            deletedAt: null,
          },
        },
      },
      orderBy: [{ raceTypeId: "desc" }, { order: "asc" }],
    },
  },
});

if (!election) {
  return Astro.redirect("/admin/elections");
}
---

<AdminLayout
  title={`Races: ${election.name}`}
  breadcrumbs={[
    { label: "Elections", href: "/admin/elections" },
    { label: election.name, href: `/admin/elections/${slug}/edit` },
    { label: "Races" },
  ]}
>
  <div class="space-y-6">
    <!-- Create Button -->
    <div class="flex justify-end">
      <a
        href={`/admin/elections/${slug}/races/create`}
        class="bg-secondary hover:bg-secondary/90 focus:ring-secondary inline-flex items-center rounded-lg px-4 py-2 text-white transition-colors focus:ring-2 focus:ring-offset-2"
      >
        <Plus size="18" stroke-width={2} class="mr-2" />
        New Race
      </a>
    </div>

    <!-- Races Table -->
    {
      election.races.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full" id="races-table">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="w-10 px-4 py-3" />
                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">
                  Name
                </th>
                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">
                  Description
                </th>
                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">
                  Candidates
                </th>
                <th class="px-4 py-3 text-center text-sm font-semibold text-gray-700">
                  Status
                </th>
                <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">
                  Actions
                </th>
              </tr>
            </thead>
            <tbody id="races-tbody" data-election-id={election.id}>
              {election.races.map((race: RaceWithCandidates) => (
                <tr
                  class="race-row group border-b border-gray-100 transition-colors hover:bg-gray-50"
                  draggable="true"
                  data-id={race.id}
                >
                  <td class="cursor-move px-4 py-3 text-gray-400">
                    <GripVertical
                      size="18"
                      class="transition-colors group-hover:text-gray-600"
                    />
                  </td>
                  <td class="px-4 py-3 text-sm font-medium text-gray-900">
                    {race.name}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-600">
                    {race.description.substring(0, 50)}
                    {race.description.length > 50 && "..."}
                  </td>
                  <td class="px-4 py-3 text-sm whitespace-nowrap text-gray-600">
                    {`${race.candidates.length} ${race.candidates.length !== 1 ? "candidates" : "candidate"}`}
                  </td>
                  <td class="status-cell px-4 py-3 text-center text-sm">
                    <span class="text-gray-400">—</span>
                  </td>
                  <td class="space-x-2 px-4 py-3 text-right text-sm">
                    <a
                      href={`/admin/elections/${slug}/races/${race.slug}/edit`}
                      class="inline-flex items-center rounded-md bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700 transition-colors hover:bg-blue-200"
                    >
                      Edit
                    </a>
                    <a
                      href={`/admin/elections/${slug}/races/${race.slug}/candidates`}
                      class="inline-flex items-center rounded-md bg-green-100 px-3 py-1 text-xs font-medium text-green-700 transition-colors hover:bg-green-200"
                    >
                      Candidates
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="py-12 text-center">
          <p class="text-gray-500">No races yet. Create one to get started!</p>
        </div>
      )
    }
  </div>

  <script>
    import { actions } from "astro:actions";

    const tbody = document.getElementById("races-tbody") as HTMLElement;
    const electionId = tbody?.dataset.electionId;
    let draggedRow: HTMLElement | null = null;

    tbody?.addEventListener("dragstart", (e: DragEvent) => {
      draggedRow = (e.target as HTMLElement).closest(".race-row");
      if (draggedRow && e.dataTransfer) {
        draggedRow.classList.add("opacity-50", "bg-gray-100");
        e.dataTransfer.effectAllowed = "move";
      }
    });

    tbody?.addEventListener("dragend", () => {
      if (draggedRow) {
        draggedRow.classList.remove("opacity-50", "bg-gray-100");
        draggedRow = null;
      }

      // Clean up hover states
      document.querySelectorAll(".race-row").forEach((row) => {
        row.classList.remove("border-t-2", "border-secondary");
      });
    });

    tbody?.addEventListener("dragover", (e: DragEvent) => {
      e.preventDefault();
      const target = (e.target as HTMLElement).closest(
        ".race-row",
      ) as HTMLElement;
      if (target && draggedRow && target !== draggedRow) {
        const rect = target.getBoundingClientRect();
        const next = (e.clientY - rect.top) / (rect.bottom - rect.top) > 0.5;

        // Remove border from all rows first
        document.querySelectorAll(".race-row").forEach((row) => {
          row.classList.remove("border-t-2", "border-b-2", "border-secondary");
        });

        if (next) {
          target.classList.add("border-b-2", "border-secondary");
        } else {
          target.classList.add("border-t-2", "border-secondary");
        }
      }
    });

    tbody?.addEventListener("drop", async (e: DragEvent) => {
      e.preventDefault();
      const target = (e.target as HTMLElement).closest(
        ".race-row",
      ) as HTMLElement;

      if (target && draggedRow && target !== draggedRow) {
        const rect = target.getBoundingClientRect();
        const next = (e.clientY - rect.top) / (rect.bottom - rect.top) > 0.5;

        if (next) {
          target.after(draggedRow);
        } else {
          target.before(draggedRow);
        }

        // Trigger save
        await saveOrder();
      }

      // Clean up
      document.querySelectorAll(".race-row").forEach((row) => {
        row.classList.remove("border-t-2", "border-b-2", "border-secondary");
      });
    });

    async function saveOrder() {
      const rows = Array.from(
        document.querySelectorAll(".race-row"),
      ) as HTMLElement[];
      const updates = rows.map((row, index) => ({
        id: row.dataset.id || "",
        order: index,
      }));

      // Find the row that was just moved (or just show status on all affected)
      // For simplicity, we'll show a global indicator or status on the first row
      const firstStatusCell = rows[0]?.querySelector(".status-cell");
      if (firstStatusCell) {
        firstStatusCell.innerHTML =
          '<span class="text-blue-500 animate-pulse">Saving...</span>';
      }

      try {
        if (!electionId) throw new Error("Missing electionId");

        const { error } = await actions.reorderRaces({
          electionId,
          updates,
        });

        if (error) {
          console.error("Reorder error:", error);
          window.toast.error(error.message || "Failed to save order");
          if (firstStatusCell) {
            firstStatusCell.innerHTML =
              '<span class="text-red-500 text-xs font-medium">Error</span>';
          }
        } else {
          if (firstStatusCell) {
            firstStatusCell.innerHTML =
              '<span class="text-green-500 text-xs font-bold">Saved</span>';
            setTimeout(() => {
              firstStatusCell.innerHTML =
                '<span class="text-gray-400">—</span>';
            }, 2000);
          }
        }
      } catch (err) {
        console.error("Exception:", err);
        window.toast.error("Network error while saving order.");
        if (firstStatusCell) {
          firstStatusCell.innerHTML =
            '<span class="text-red-500 text-xs font-medium">Failed</span>';
        }
      }
    }
  </script>
</AdminLayout>

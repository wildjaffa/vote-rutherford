---
import AdminLayout from "../../../../../layouts/AdminLayout.astro";
import FormInput from "../../../../../components/forms/FormInput.astro";
import FormTextarea from "../../../../../components/forms/FormTextarea.astro";
import FormSelect from "../../../../../components/forms/FormSelect.astro";
import { actions } from "astro:actions";
import Button from "../../../../../components/Button.astro";
import prisma from "../../../../../lib/prisma";
import {
  DistrictType,
  type RaceType,
} from "../../../../../generated/prisma/browser";
import { PartyCategories } from "../../../../../constants";

export const prerender = false;

const { slug: electionSlug } = Astro.params;

if (!electionSlug) {
  return Astro.redirect("/admin/elections");
}

const election = await prisma.election.findUnique({
  where: { slug: electionSlug },
});

if (!election) {
  return Astro.redirect("/admin/elections");
}

// Get race types for dropdown
const raceTypes = await prisma.raceType.findMany();
const raceTypeOptions = raceTypes.map((rt: RaceType) => ({
  value: rt.id.toString(),
  label: rt.value,
}));

// Get districts for dropdown
const districts = await prisma.district.findMany({
  where: { deletedAt: null },
});

districts.sort((a, b) => {
  const typeCompare = a.type.localeCompare(b.type);
  if (typeCompare !== 0) return typeCompare;
  return a.name.localeCompare(b.name, undefined, {
    numeric: true,
    sensitivity: "base",
  });
});

const districtTypes = Object.values(DistrictType);
const districtTypeOptions = districtTypes.map((type) => ({
  value: type,
  label: type.replace(/_/g, " "),
}));

// Get earlier elections for Source Races
const earlierElections = await prisma.election.findMany({
  where: { date: { lte: election.date }, deletedAt: null },
  orderBy: { date: "desc" },
  include: { races: { where: { deletedAt: null }, orderBy: { order: "asc" } } },
});

let error: string | null = null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const name = formData.get("name") as string;
    const shortName = formData.get("shortName") as string | null;
    const raceTypeId = parseInt(formData.get("raceType") as string);
    const description = formData.get("description") as string;
    const status = formData.get("status") as string;
    const slug = formData.get("slug") as string;
    const districtId = formData.get("districtId") as string | null;
    const partyCategory = formData.get("partyCategory") as string;
    const order = parseInt(formData.get("order") as string) || 0;

    const result = await Astro.callAction(actions.createRace, {
      electionId: election.id,
      name,
      shortName: shortName || undefined,
      partyCategory,
      raceTypeId,
      description,
      status,
      slug,
      order,
      numSelections: parseInt(formData.get("numSelections") as string) || 1,
      sourceRaceIds: formData.getAll("sourceRaceIds") as string[],
      ...(districtId && { districtId }),
    });

    if (result.data) {
      return Astro.redirect(
        `/admin/elections/${electionSlug}/races/${result.data.data.slug}/edit`,
      );
    }
  } catch (err) {
    error = err instanceof Error ? err.message : "Failed to create race";
  }
}
---

<AdminLayout
  title="Create Race"
  breadcrumbs={[
    { label: "Elections", href: "/admin/elections" },
    { label: election.name, href: `/admin/elections/${electionSlug}/edit` },
    { label: "Races", href: `/admin/elections/${electionSlug}/races` },
    { label: "Create" },
  ]}
>
  <form method="POST" class="max-w-2xl space-y-6">
    {
      error && (
        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
          <p class="text-sm font-medium text-red-800">{error}</p>
        </div>
      )
    }

    <FormInput
      label="Race Name"
      name="name"
      type="text"
      placeholder="e.g., Mayor"
      required
    />
    <FormInput
      label="Short Race Name"
      name="shortName"
      type="text"
      placeholder="e.g., Commissioner 13 (shown on ballot summary)"
    />
    <FormInput
      label="Slug"
      name="slug"
      type="text"
      placeholder="e.g., mayor"
      required
    />

    <FormSelect
      label="Race Type"
      name="raceType"
      options={raceTypeOptions}
      required
    />

    <FormSelect
      label="District Type (Optional)"
      name="districtType"
      options={[
        { value: "", label: "-- All Districts --" },
        ...districtTypeOptions,
      ]}
    />

    <FormSelect
      label="District (Optional)"
      name="districtId"
      options={[
        { value: "", label: "-- No District --" },
        ...districts.map((d) => ({
          value: d.id,
          label: `${d.name}${d.number ? ` #${d.number}` : ""} (${d.type.replace(/_/g, " ")})`,
        })),
      ]}
    />

    <FormSelect
      label="Party Category"
      name="partyCategory"
      options={[
        { value: PartyCategories.GENERAL, label: PartyCategories.GENERAL },
        {
          value: PartyCategories.DEMOCRATIC,
          label: PartyCategories.DEMOCRATIC,
        },
        {
          value: PartyCategories.REPUBLICAN,
          label: PartyCategories.REPUBLICAN,
        },
      ]}
      required
    />

    <FormInput
      label="Number of Selections"
      name="numSelections"
      type="number"
      value="1"
      required
    />

    <FormInput label="Order" name="order" type="number" value="0" required />

    <FormSelect
      label="Status"
      name="status"
      options={[
        { value: "draft", label: "Draft" },
        { value: "published", label: "Published" },
      ]}
      required
    />

    <FormTextarea
      label="Description"
      name="description"
      placeholder="Enter race description..."
    />

    <div class="space-y-3">
      <label class="block text-sm font-medium text-gray-700"
        >Source Races (Optional)</label
      >
      <p class="text-xs text-gray-500">
        Select races from previous elections that this race is based on.
      </p>
      <div
        class="max-h-64 space-y-6 overflow-y-auto rounded-md border border-gray-300 bg-white p-4"
      >
        {
          earlierElections.map((previousElection) => (
            <div>
              <h4 class="font-medium text-gray-900">
                {previousElection.name} (
                {new Date(previousElection.date).toLocaleDateString()})
              </h4>
              <div class="mt-2 space-y-2 pl-4">
                {previousElection.races.map((race) => (
                  <label class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      name="sourceRaceIds"
                      value={race.id}
                      class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                    />
                    <span class="text-sm text-gray-700">
                      {race.name}{" "}
                      {race.partyCategory !== "General Election"
                        ? `(${race.partyCategory})`
                        : ""}
                    </span>
                  </label>
                ))}
                {previousElection.races.length === 0 && (
                  <span class="text-sm text-gray-400 italic">
                    No races configured
                  </span>
                )}
              </div>
            </div>
          ))
        }
        {
          earlierElections.length === 0 && (
            <span class="text-sm text-gray-500 italic">
              No previous elections found
            </span>
          )
        }
      </div>
    </div>

    <div class="flex justify-end gap-3 pt-4">
      <Button
        variant="secondary"
        href={`/admin/elections/${electionSlug}/races`}>Cancel</Button
      >
      <Button type="submit">Create Race</Button>
    </div>
  </form>
</AdminLayout>

<script>
  import { generateSlug } from "../../../../../lib/slugUtils";

  const nameInput = document.querySelector(
    'input[name="name"]',
  ) as HTMLInputElement;
  const slugInput = document.querySelector(
    'input[name="slug"]',
  ) as HTMLInputElement;

  if (nameInput && slugInput) {
    nameInput.addEventListener("input", (e) => {
      const value = (e.target as HTMLInputElement).value;
      slugInput.value = generateSlug(value);
    });
  }

  // Districts map with their types - passed from server
  //const districtsByType: Record<
  //  string,
  //  Array<{ id: string; name: string; number?: number; type: string }>
  //> = {
  //  US_HOUSE: [],
  //  STATE_SENATE: [],
  //  STATE_HOUSE: [],
  //  JUDICIAL: [],
  //  COUNTY: [],
  //  MUNICIPAL: [],
  //  SCHOOL: [],
  //  ROAD: [],
  //  PRECINCT: [],
  //};

  // Populate districts from the rendered options
  const districtSelect = document.querySelector(
    'select[name="districtId"]',
  ) as HTMLSelectElement;

  if (districtSelect) {
    // Store all options
    const allOptions = Array.from(districtSelect.options).map((opt) => ({
      value: opt.value,
      text: opt.text,
      type: opt.text.match(/\(([^)]+)\)/)?.[1] || "",
    }));

    const districtTypeSelect = document.querySelector(
      'select[name="districtType"]',
    ) as HTMLSelectElement;

    if (districtTypeSelect) {
      districtTypeSelect.addEventListener("change", (e) => {
        const selectedType = (e.target as HTMLSelectElement).value;

        // Clear current options except the first one
        while (districtSelect.options.length > 1) {
          districtSelect.remove(1);
        }

        // Add filtered options
        const filtered =
          selectedType === ""
            ? allOptions.filter((opt) => opt.value !== "")
            : allOptions.filter((opt) => opt.type === selectedType);

        filtered.forEach((opt) => {
          const optionEl = document.createElement("option");
          optionEl.value = opt.value;
          optionEl.text = opt.text;
          districtSelect.appendChild(optionEl);
        });
      });
    }
  }
</script>

---
import { actions } from "astro:actions";
import DeleteButton from "../../../../../../../../components/forms/DeleteButton.astro";
import FormInput from "../../../../../../../../components/forms/FormInput.astro";
import FormTextarea from "../../../../../../../../components/forms/FormTextarea.astro";
import AdminLayout from "../../../../../../../../layouts/AdminLayout.astro";
import prisma from "../../../../../../../../lib/prisma";
import { convertKeyToPublicUrl } from "../../../../../../../../lib/blobStorage";
import { Facebook, Instagram, Threads, X, Youtube } from "simple-icons-astro";
import { Linkedin, Globe } from "@lucide/astro";

export const prerender = false;

const { slug: electionSlug, raceSlug, candidateSlug } = Astro.params;

if (!electionSlug || !raceSlug || !candidateSlug) {
  return Astro.redirect("/admin/elections");
}

const candidate = await prisma.candidate.findFirst({
  where: {
    slug: candidateSlug,
    race: { slug: raceSlug, election: { slug: electionSlug } },
  },
  include: {
    race: { include: { election: true } },
    profileImage: true,
    externalLinks: { include: { externalLinkType: true } },
  },
});

if (!candidate) {
  return Astro.redirect(
    `/admin/elections/${electionSlug}/races/${raceSlug}/candidates`,
  );
}

const race = candidate.race;

if (!race || race.id !== candidate.raceId) {
  return Astro.redirect(`/admin/elections/${electionSlug}/races`);
}

const election = race.election;

if (!election || race.electionId !== election.id) {
  return Astro.redirect(`/admin/elections/${electionSlug}/races`);
}

let error: string | null = null;
let success: string | null = null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    const result = await Astro.callAction(actions.updateCandidate, {
      id: candidate.id,
      firstName: formData.get("firstName") as string,
      lastName: formData.get("lastName") as string,
      birthYear: (formData.get("birthYear") as string) || undefined, // Schema handles string -> number coercion
      biography: (formData.get("biography") as string) || undefined,
      profileImageId: (formData.get("profileImageId") as string) || undefined,
      slug: candidateSlug,
      facebookUrl: (formData.get("facebookUrl") as string) || undefined,
      xUrl: (formData.get("xUrl") as string) || undefined,
      instagramUrl: (formData.get("instagramUrl") as string) || undefined,
      linkedInUrl: (formData.get("linkedInUrl") as string) || undefined,
      youtubeUrl: (formData.get("youtubeUrl") as string) || undefined,
      threadsUrl: (formData.get("threadsUrl") as string) || undefined,
      websiteUrl: (formData.get("websiteUrl") as string) || undefined,
    });

    if (result.error) {
      error = result.error.message || "Failed to update candidate";
    } else if (result.data) {
      success = "Candidate updated successfully";
      // Refetch the candidate to show updated data
      const updatedCandidate = await prisma.candidate.findUnique({
        where: { id: candidate.id },
        include: {
          race: true,
          profileImage: true,
        },
      });
      if (updatedCandidate) {
        Object.assign(candidate, updatedCandidate);
      }
    }
  } catch (err) {
    error = err instanceof Error ? err.message : "Failed to update candidate";
  }
}

const fullName = `${candidate.firstName} ${candidate.lastName}`;
const profileImageUrl = convertKeyToPublicUrl(
  candidate.profileImage?.fileLocation,
);
---

<AdminLayout
  title={`Edit Candidate: ${fullName}`}
  breadcrumbs={[
    { label: "Elections", href: "/admin/elections" },
    { label: election.name, href: `/admin/elections/${electionSlug}/edit` },
    { label: "Races", href: `/admin/elections/${electionSlug}/races` },
    {
      label: race.name,
      href: `/admin/elections/${electionSlug}/races/${raceSlug}/edit`,
    },
    {
      label: "Candidates",
      href: `/admin/elections/${electionSlug}/races/${raceSlug}/candidates`,
    },
    { label: fullName },
  ]}
>
  <div class="space-y-6">
    {
      error && (
        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
          <p class="text-sm font-medium text-red-800">{error}</p>
        </div>
      )
    }

    {
      success && (
        <div class="rounded-lg border border-green-200 bg-green-50 p-4">
          <p class="text-sm font-medium text-green-800">{success}</p>
        </div>
      )
    }

    <form method="POST" class="max-w-2xl space-y-6">
      <div class="grid grid-cols-2 gap-4">
        <FormInput
          label="First Name"
          name="firstName"
          type="text"
          value={candidate.firstName}
          placeholder="First name"
        />
        <FormInput
          label="Last Name"
          name="lastName"
          type="text"
          value={candidate.lastName}
          placeholder="Last name"
        />
      </div>

      <FormInput
        label="Birth Year"
        name="birthYear"
        type="number"
        value={candidate.birthYear || ""}
        placeholder="e.g., 1980"
        min="1900"
      />

      <FormTextarea
        label="Biography"
        name="biography"
        value={candidate.biography || ""}
        placeholder="Enter candidate biography..."
      />

      <FormInput
        label="Facebook URL"
        name="facebookUrl"
        type="url"
        value={candidate.externalLinks.find(
          (link) => link.externalLinkType.value === "Facebook",
        )?.hyperlink || ""}
        placeholder="Facebook URL"><Facebook slot="start" /></FormInput
      >

      <FormInput
        label="X URL"
        name="xUrl"
        type="url"
        value={candidate.externalLinks.find(
          (link) => link.externalLinkType.value === "X",
        )?.hyperlink || ""}
        placeholder="X URL"><X slot="start" /></FormInput
      >

      <FormInput
        label="Instagram URL"
        name="instagramUrl"
        type="url"
        value={candidate.externalLinks.find(
          (link) => link.externalLinkType.value === "Instagram",
        )?.hyperlink || ""}
        placeholder="Instagram URL"><Instagram slot="start" /></FormInput
      >

      <FormInput
        label="LinkedIn URL"
        name="linkedInUrl"
        type="url"
        value={candidate.externalLinks.find(
          (link) => link.externalLinkType.value === "LinkedIn",
        )?.hyperlink || ""}
        placeholder="LinkedIn URL"><Linkedin slot="start" /></FormInput
      >

      <FormInput
        label="YouTube URL"
        name="youtubeUrl"
        type="url"
        value={candidate.externalLinks.find(
          (link) => link.externalLinkType.value === "YouTube",
        )?.hyperlink || ""}
        placeholder="YouTube URL"><Youtube slot="start" /></FormInput
      >

      <FormInput
        label="Threads URL"
        name="threadsUrl"
        type="url"
        value={candidate.externalLinks.find(
          (link) => link.externalLinkType.value === "Threads",
        )?.hyperlink || ""}
        placeholder="Threads URL"><Threads slot="start" /></FormInput
      >

      <FormInput
        label="Website URL"
        name="websiteUrl"
        type="url"
        value={candidate.externalLinks.find(
          (link) => link.externalLinkType.value === "Website",
        )?.hyperlink || ""}
        placeholder="Website URL"><Globe slot="start" /></FormInput
      >

      <div>
        <label class="block text-sm font-medium text-gray-700"
          >Profile Image</label
        >
        {
          profileImageUrl && (
            <img
              src={profileImageUrl}
              alt="Profile"
              class="mb-2 h-24 w-24 rounded-md object-cover"
            />
          )
        }
        <input
          type="file"
          accept="image/*"
          id="profileImageInput"
          class="bg-primary mt-1 block rounded-md border border-gray-300"
        />
        <input
          type="hidden"
          name="profileImageId"
          id="profileImageId"
          value={candidate.profileImageId || ""}
        />
        <p id="profileImageStatus" class="mt-1 text-xs text-gray-500"></p>
      </div>

      <div class="flex justify-end gap-3 border-t border-gray-200 pt-4">
        <a
          href={`/admin/elections/${electionSlug}/races/${raceSlug}/candidates`}
          class="inline-flex items-center rounded-lg border border-gray-300 px-4 py-2 text-gray-700 transition-colors hover:bg-gray-50"
        >
          Cancel
        </a>
        <button
          type="submit"
          class="bg-secondary hover:bg-secondary/90 focus:ring-secondary inline-flex items-center rounded-lg px-4 py-2 text-white transition-colors focus:ring-2 focus:ring-offset-2"
        >
          Save Changes
        </button>
      </div>

      <script type="module">
        const input = document.getElementById("profileImageInput");
        const hidden = document.getElementById("profileImageId");
        const status = document.getElementById("profileImageStatus");

        input.addEventListener("change", async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          if (!file.type.startsWith("image/")) {
            status.textContent = "Only images allowed";
            return;
          }
          if (file.size > 5 * 1024 * 1024) {
            status.textContent = "File must be <= 5 MB";
            return;
          }
          status.textContent = "Uploading...";
          const fd = new FormData();
          fd.append("file", file);
          try {
            const res = await fetch("/api/admin/blobs/upload.json", {
              method: "POST",
              body: fd,
            });
            if (!res.ok) {
              const err = await res.json();
              status.textContent = err.error || "Upload failed";
              return;
            }
            const data = await res.json();
            hidden.value = data.id;
            status.textContent = "Uploaded";
          } catch (err) {
            console.error(err);
            status.textContent = "Upload failed";
          }
        });
      </script>
    </form>

    <!-- Danger Zone -->
    <div class="border-t border-gray-200 pt-6">
      <h3 class="mb-4 text-lg font-semibold text-red-900">Danger Zone</h3>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <p class="mb-4 text-sm text-red-800">
          Deleting this candidate will archive them and hide them from public
          view.
        </p>
        <DeleteButton
          itemName={fullName}
          deleteUrl={`/api/admin/candidates/${candidate.id}/delete.json`}
          redirectUrl={`/admin/elections/${electionSlug}/races/${raceSlug}/candidates`}
        />
      </div>
    </div>
  </div>
</AdminLayout>

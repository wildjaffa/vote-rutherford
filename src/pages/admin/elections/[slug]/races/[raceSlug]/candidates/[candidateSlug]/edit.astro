---
import { actions } from "astro:actions";
import DeleteButton from "../../../../../../../../components/forms/DeleteButton.astro";
import FormInput from "../../../../../../../../components/forms/FormInput.astro";
import FormTextarea from "../../../../../../../../components/forms/FormTextarea.astro";
import AdminLayout from "../../../../../../../../layouts/AdminLayout.astro";
import prisma from "../../../../../../../../lib/prisma";

export const prerender = false;

const { slug: electionSlug, raceSlug, candidateSlug } = Astro.params;

if (!electionSlug || !raceSlug || !candidateSlug) {
  return Astro.redirect("/admin/elections");
}

const candidate = await prisma.candidate.findFirst({
  where: {
    slug: candidateSlug,
    race: { slug: raceSlug, election: { slug: electionSlug } },
  },
  include: {
    race: { include: { election: true } },
  },
});

if (!candidate) {
  return Astro.redirect(
    `/admin/elections/${electionSlug}/races/${raceSlug}/candidates`,
  );
}

const race = candidate.race;

if (!race || race.id !== candidate.raceId) {
  return Astro.redirect(`/admin/elections/${electionSlug}/races`);
}

const election = race.election;

if (!election || race.electionId !== election.id) {
  return Astro.redirect(`/admin/elections/${electionSlug}/races`);
}

let error: string | null = null;
let success: string | null = null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const firstName = formData.get("firstName") as string;
    const lastName = formData.get("lastName") as string;
    const birthYear = formData.get("birthYear") as string;
    const biography = formData.get("biography") as string;

    const result = await Astro.callAction(actions.updateCandidate, {
      id: candidate.id,
      firstName: firstName || undefined,
      lastName: lastName || undefined,
      birthYear: birthYear ? parseInt(birthYear, 10) : undefined,
      biography: biography || undefined,
    });

    if (result.error) {
      error = result.error.message || "Failed to update candidate";
    } else if (result.data) {
      success = "Candidate updated successfully";
      // Refetch the candidate to show updated data
      const updatedCandidate = await prisma.candidate.findUnique({
        where: { id: candidate.id },
        include: {
          race: true,
        },
      });
      if (updatedCandidate) {
        Object.assign(candidate, updatedCandidate);
      }
    }
  } catch (err) {
    error = err instanceof Error ? err.message : "Failed to update candidate";
  }
}

const fullName = `${candidate.firstName} ${candidate.lastName}`;
---

<AdminLayout
  title={`Edit Candidate: ${fullName}`}
  breadcrumbs={[
    { label: "Elections", href: "/admin/elections" },
    { label: election.name, href: `/admin/elections/${electionSlug}/edit` },
    { label: "Races", href: `/admin/elections/${electionSlug}/races` },
    {
      label: race.name,
      href: `/admin/elections/${electionSlug}/races/${raceSlug}/edit`,
    },
    {
      label: "Candidates",
      href: `/admin/elections/${electionSlug}/races/${raceSlug}/candidates`,
    },
    { label: fullName },
  ]}
>
  <div class="space-y-6">
    {
      error && (
        <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm font-medium text-red-800">{error}</p>
        </div>
      )
    }

    {
      success && (
        <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
          <p class="text-sm font-medium text-green-800">{success}</p>
        </div>
      )
    }

    <form method="POST" class="max-w-2xl space-y-6">
      <div class="grid grid-cols-2 gap-4">
        <FormInput
          label="First Name"
          name="firstName"
          type="text"
          value={candidate.firstName}
          placeholder="First name"
        />
        <FormInput
          label="Last Name"
          name="lastName"
          type="text"
          value={candidate.lastName}
          placeholder="Last name"
        />
      </div>

      <FormInput
        label="Birth Year"
        name="birthYear"
        type="number"
        value={candidate.birthYear || ""}
        placeholder="e.g., 1980"
        min="1900"
      />

      <FormTextarea
        label="Biography"
        name="biography"
        value={candidate.biography || ""}
        placeholder="Enter candidate biography..."
      />

      <div class="flex gap-3 justify-end pt-4 border-t border-gray-200">
        <a
          href={`/admin/elections/${electionSlug}/races/${raceSlug}/candidates`}
          class="inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
        >
          Cancel
        </a>
        <button
          type="submit"
          class="inline-flex items-center px-4 py-2 bg-secondary text-white rounded-lg hover:bg-secondary/90 transition-colors focus:ring-2 focus:ring-secondary focus:ring-offset-2"
        >
          Save Changes
        </button>
      </div>
    </form>

    <!-- Danger Zone -->
    <div class="border-t border-gray-200 pt-6">
      <h3 class="text-lg font-semibold text-red-900 mb-4">Danger Zone</h3>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <p class="text-sm text-red-800 mb-4">
          Deleting this candidate will archive them and hide them from public
          view.
        </p>
        <DeleteButton
          itemName={fullName}
          deleteUrl={`/api/admin/candidates/${candidate.id}/delete.json`}
          redirectUrl={`/admin/elections/${electionSlug}/races/${raceSlug}/candidates`}
        />
      </div>
    </div>
  </div>
</AdminLayout>

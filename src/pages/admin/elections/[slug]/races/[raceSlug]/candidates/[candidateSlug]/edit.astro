---
import { actions } from "astro:actions";
import DeleteButton from "../../../../../../../../components/forms/DeleteButton.astro";
import FormInput from "../../../../../../../../components/forms/FormInput.astro";
import AdminLayout from "../../../../../../../../layouts/AdminLayout.astro";
import Button from "../../../../../../../../components/Button.astro";
import FormExternalLinkInput from "../../../../../../../../components/forms/FormExternalLinkInput.astro";
import FormCandidatePolicyResponseInput from "../../../../../../../../components/forms/FormCandidatePolicyResponseInput.astro";
import prisma from "../../../../../../../../lib/prisma";
import { convertKeyToPublicUrl } from "../../../../../../../../lib/blobStorage";
import FormQualificationInput from "../../../../../../../../components/forms/FormQualificationInput.astro";

export const prerender = false;

const { slug: electionSlug, raceSlug, candidateSlug } = Astro.params;

if (!electionSlug || !raceSlug || !candidateSlug) {
  return Astro.redirect("/admin/elections");
}

const candidate = await prisma.candidate.findFirst({
  where: {
    slug: candidateSlug,
    race: { slug: raceSlug, election: { slug: electionSlug } },
  },
  include: {
    race: {
      include: {
        election: {
          include: {
            policyQuestions: true,
          },
        },
        policyQuestionsToRaces: true,
      },
    },
    profileImage: true,
    externalLinks: { include: { externalLinkType: true } },
    policyResponses: {
      include: {
        clarifications: true,
      },
    },
    qualifications: { include: { qualificationType: true } },
  },
});

if (!candidate) {
  return Astro.redirect(
    `/admin/elections/${electionSlug}/races/${raceSlug}/candidates`,
  );
}

const race = candidate.race;

if (!race || race.id !== candidate.raceId) {
  return Astro.redirect(`/admin/elections/${electionSlug}/races`);
}

const election = race.election;

if (!election || race.electionId !== election.id) {
  return Astro.redirect(`/admin/elections/${electionSlug}/races`);
}

const prioritizedQuestionIds = race.policyQuestionsToRaces.map(
  (p) => p.policyQuestionId,
);

const questions = election.policyQuestions.map((q) => ({
  ...q,
  isPrioritized: prioritizedQuestionIds.includes(q.id),
}));

let error: string | null = null;
let success: string | null = null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    console.log("Form Data:", Object.fromEntries(formData.entries())); // Debug log
    const externalLinksUrls = formData.getAll("link-url") as string[];
    const externalLinksTypes = formData.getAll("link-type") as string[];
    const externalLinksTexts = formData.getAll("link-displayText") as string[];
    const externalLinksIds = formData.getAll("link-id") as string[];

    const externalLinks = externalLinksUrls
      .map((url, i) => ({
        url,
        type: externalLinksTypes[i] as string,
        displayText: externalLinksTexts[i] || null,
        id: externalLinksIds[i] || undefined,
      }))
      .filter((l) => l.url);

    const qualificationTypes = formData.getAll(
      "qualification-type",
    ) as string[];
    const qualificationUrls = formData.getAll("qualification-url") as string[];
    const qualificationDisplayTexts = formData.getAll(
      "qualification-displayText",
    ) as string[];
    const qualificationIds = formData.getAll("qualification-id") as string[];

    const qualifications = qualificationTypes
      .map((type, i) => ({
        type,
        url: qualificationUrls[i] || null,
        displayText: qualificationDisplayTexts[i] as string,
        id: qualificationIds[i] || undefined,
      }))
      .filter((q) => q.type);

    const responseIds = formData.getAll("response-id") as string[];
    const responseQuestionIds = formData.getAll(
      "response-question-id",
    ) as string[];
    const responseTexts = formData.getAll("response-text") as string[];

    const policyResponses = responseQuestionIds
      .map((questionId, i) => {
        const clarificationIds = formData.getAll(
          `clarification-id-${questionId}`,
        ) as string[];
        const clarificationTexts = formData.getAll(
          `clarification-text-${questionId}`,
        ) as string[];

        const clarifications = clarificationTexts
          .map((text, j) => ({
            id: clarificationIds[j] || undefined,
            clarificationText: text,
          }))
          .filter((c) => c.clarificationText.trim());

        return {
          id: responseIds[i] || undefined,
          questionId,
          responseText: responseTexts[i] || "",
          clarifications,
        };
      })
      .filter((r) => r.responseText.trim() || r.clarifications?.length);

    const result = await Astro.callAction(actions.updateCandidate, {
      id: candidate.id,
      firstName: formData.get("firstName") as string,
      lastName: formData.get("lastName") as string,
      partyAffiliation: formData.get("partyAffiliation") as string,
      birthYear: (formData.get("birthYear") as string) || undefined, // Schema handles string -> number coercion
      profileImageId: (formData.get("profileImageId") as string) || undefined,
      isIncumbent: formData.get("isIncumbent") === "on",
      slug: candidateSlug,
      externalLinks,
      policyResponses,
      qualifications,
    });

    if (result.error) {
      error = result.error.message || "Failed to update candidate";
    } else if (result.data) {
      success = "Candidate updated successfully";
      // Refetch the candidate to show updated data
      const updatedCandidate = await prisma.candidate.findUnique({
        where: { id: candidate.id },
        include: {
          race: true,
          profileImage: true,
          externalLinks: { include: { externalLinkType: true } },
          qualifications: { include: { qualificationType: true } },
        },
      });
      if (updatedCandidate) {
        Object.assign(candidate, updatedCandidate);
      }
    }
  } catch (err) {
    error = err instanceof Error ? err.message : "Failed to update candidate";
  }
}

const fullName = `${candidate.firstName} ${candidate.lastName}`;
const profileImageUrl = convertKeyToPublicUrl(
  candidate.profileImage?.fileLocation,
);
---

<AdminLayout
  title={`Edit Candidate: ${fullName}`}
  breadcrumbs={[
    { label: "Elections", href: "/admin/elections" },
    { label: election.name, href: `/admin/elections/${electionSlug}/edit` },
    { label: "Races", href: `/admin/elections/${electionSlug}/races` },
    {
      label: race.name,
      href: `/admin/elections/${electionSlug}/races/${raceSlug}/edit`,
    },
    {
      label: "Candidates",
      href: `/admin/elections/${electionSlug}/races/${raceSlug}/candidates`,
    },
    { label: fullName },
  ]}
>
  <div class="space-y-6">
    {
      error && (
        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
          <p class="text-sm font-medium text-red-800">{error}</p>
        </div>
      )
    }

    {
      success && (
        <div class="rounded-lg border border-green-200 bg-green-50 p-4">
          <p class="text-sm font-medium text-green-800">{success}</p>
        </div>
      )
    }

    <form method="POST" class="max-w-2xl space-y-6">
      <div class="grid grid-cols-2 gap-4">
        <FormInput
          label="First Name"
          name="firstName"
          type="text"
          value={candidate.firstName}
          placeholder="First name"
          required
        />
        <FormInput
          label="Last Name"
          name="lastName"
          type="text"
          value={candidate.lastName}
          placeholder="Last name"
          required
        />

        <FormInput
          label="Party Affiliation"
          name="partyAffiliation"
          type="text"
          value={candidate.partyAffiliation || ""}
          placeholder="e.g., Moose Party"
          required
        />
        <FormInput
          label="Birth Year"
          name="birthYear"
          type="number"
          value={candidate.birthYear || ""}
          placeholder="e.g., 1980"
          min="1900"
        />
      </div>

      <FormExternalLinkInput
        links={candidate.externalLinks.map((l) => ({
          id: l.id,
          type: l.externalLinkType.value,
          url: l.hyperlink,
          displayText: l.displayText,
        }))}
      />

      <hr class="border-gray-200" />

      <FormQualificationInput
        qualifications={candidate.qualifications.map((q) => ({
          id: q.id,
          type: q.qualificationType.value,
          url: q.qualification_url,
          displayText: q.qualification_description,
        }))}
      />

      <hr class="border-gray-200" />

      <FormCandidatePolicyResponseInput
        questions={questions}
        existingResponses={candidate.policyResponses.map((r) => ({
          id: r.id,
          policyQuestionId: r.policyQuestionId,
          response: r.response,
          clarifications: r.clarifications.map((c) => ({
            id: c.id,
            clarification: c.clarification,
          })),
        }))}
      />

      <FormInput
        label="Is Incumbent"
        name="isIncumbent"
        type="checkbox"
        value={candidate.isIncumbent ? "on" : "off"}
      />

      <div>
        <label class="block text-sm font-medium text-gray-700"
          >Profile Image</label
        >
        {
          profileImageUrl && (
            <img
              src={profileImageUrl}
              alt="Profile"
              class="mb-2 h-24 w-24 rounded-md object-cover"
            />
          )
        }
        <input
          type="file"
          accept="image/*"
          id="profileImageInput"
          class="bg-primary mt-1 block rounded-md border border-gray-300"
        />
        <input
          type="hidden"
          name="profileImageId"
          id="profileImageId"
          value={candidate.profileImageId || ""}
        />
        <p id="profileImageStatus" class="mt-1 text-xs text-gray-500"></p>
      </div>

      <div class="flex justify-end gap-3 border-t border-gray-200 pt-4">
        <Button
          variant="secondary"
          href={`/admin/elections/${electionSlug}/races/${raceSlug}/candidates`}
        >
          Cancel
        </Button>
        <Button type="submit">Save Changes</Button>
      </div>

      <script type="module">
        const input = document.getElementById("profileImageInput");
        const hidden = document.getElementById("profileImageId");
        const status = document.getElementById("profileImageStatus");

        input.addEventListener("change", async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          if (!file.type.startsWith("image/")) {
            status.textContent = "Only images allowed";
            return;
          }
          if (file.size > 5 * 1024 * 1024) {
            status.textContent = "File must be <= 5 MB";
            return;
          }
          status.textContent = "Uploading...";
          const fd = new FormData();
          fd.append("file", file);
          try {
            const res = await fetch("/api/admin/blobs/upload.json", {
              method: "POST",
              body: fd,
            });
            if (!res.ok) {
              const err = await res.json();
              status.textContent = err.error || "Upload failed";
              return;
            }
            const data = await res.json();
            hidden.value = data.id;
            status.textContent = "Uploaded";
          } catch (err) {
            console.error(err);
            status.textContent = "Upload failed";
          }
        });
      </script>
    </form>

    <!-- Danger Zone -->
    <div class="border-t border-gray-200 pt-6">
      <h3 class="mb-4 text-lg font-semibold text-red-900">Danger Zone</h3>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <p class="mb-4 text-sm text-red-800">
          Deleting this candidate will archive them and hide them from public
          view.
        </p>
        <DeleteButton
          itemName={fullName}
          deleteUrl={`/api/admin/candidates/${candidate.id}/delete.json`}
          redirectUrl={`/admin/elections/${electionSlug}/races/${raceSlug}/candidates`}
        />
      </div>
    </div>
  </div>
</AdminLayout>

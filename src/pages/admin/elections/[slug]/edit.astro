---
import { actions } from "astro:actions";
import DeleteButton from "../../../../components/forms/DeleteButton.astro";
import FormInput from "../../../../components/forms/FormInput.astro";
import FormTextarea from "../../../../components/forms/FormTextarea.astro";
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import prisma from "../../../../lib/prisma";
import type { Election } from "../../../../generated/prisma/browser";

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/admin/elections");
}

const election: Election | null = await prisma.election.findUnique({
  where: { slug },
});

if (!election) {
  return Astro.redirect("/admin/elections");
}

let error: string | null = null;
let success: string | null = null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const name = formData.get("name") as string;
    const description = formData.get("description") as string;
    const date = formData.get("date") as string;
    const slug = formData.get("slug") as string;

    const result = await Astro.callAction(actions.updateElection, {
      id: election.id,
      name: name || undefined,
      description: description || undefined,
      date: date || undefined,
      slug: slug || undefined,
    });

    if (result.data) {
      success = "Election updated successfully";
    }
  } catch (err) {
    error = err instanceof Error ? err.message : "Failed to update election";
  }
}
---

<AdminLayout
  title={`Edit Election: ${election.name}`}
  breadcrumbs={[
    { label: "Elections", href: "/admin/elections" },
    { label: election.name },
  ]}
>
  <div class="space-y-6">
    {
      error && (
        <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm font-medium text-red-800">{error}</p>
        </div>
      )
    }

    {
      success && (
        <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
          <p class="text-sm font-medium text-green-800">{success}</p>
        </div>
      )
    }

    <form method="POST" class="max-w-2xl space-y-6">
      <FormInput
        label="Election Name"
        name="name"
        type="text"
        value={election.name}
        placeholder="e.g., 2024 General Election"
      />

      <FormTextarea
        label="Description"
        name="description"
        value={election.description}
        placeholder="Enter election description..."
      />

      <FormInput
        label="Slug"
        name="slug"
        type="text"
        value={election.slug}
        placeholder="e.g., 2024-general-election"
      />

      <FormInput
        label="Election Date"
        name="date"
        type="datetime-local"
        value={election.date.toISOString().slice(0, 16)}
      />

      <div class="flex gap-3 justify-end pt-4 border-t border-gray-200">
        <a
          href="/admin/elections"
          class="inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
        >
          Cancel
        </a>
        <button
          type="submit"
          class="inline-flex items-center px-4 py-2 bg-secondary text-white rounded-lg hover:bg-secondary/90 transition-colors focus:ring-2 focus:ring-secondary focus:ring-offset-2"
        >
          Save Changes
        </button>
      </div>
    </form>

    <!-- Danger Zone -->
    <div class="border-t border-gray-200 pt-6">
      <h3 class="text-lg font-semibold text-red-900 mb-4">Danger Zone</h3>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <p class="text-sm text-red-800 mb-4">
          Deleting this election will archive it and hide it from public view.
        </p>
        <DeleteButton
          itemName={election.name}
          deleteUrl={`/api/admin/elections/${slug}/delete.json`}
          redirectUrl="/admin/elections"
        />
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Auto-generate slug from name on edit
  const nameInput = document.querySelector(
    'input[name="name"]',
  ) as HTMLInputElement;
  const slugInput = document.querySelector(
    'input[name="slug"]',
  ) as HTMLInputElement;

  if (nameInput && slugInput) {
    nameInput.addEventListener("input", (e) => {
      const value = (e.target as HTMLInputElement).value;
      const slug = value
        .toLowerCase()
        .trim()
        .replace(/\s+/g, "-")
        .replace(/[^\w-]/g, "")
        .replace(/-+/g, "-")
        .replace(/^-+|-+$/g, "");
      slugInput.value = slug;
    });
  }
</script>

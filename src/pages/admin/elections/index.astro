---
import { Plus } from "@lucide/astro";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import prisma from "../../../lib/prisma";

export const prerender = false;

const elections = await prisma.election.findMany({
  where: {
    archivedAt: null,
  },
  include: {
    races: {
      where: {
        deletedAt: null,
      },
    },
  },
  orderBy: {
    createdAt: "desc",
  },
});
---

<AdminLayout title="Elections">
  <div class="space-y-6">
    <!-- Create Button -->
    <div class="flex justify-end">
      <a
        href="/admin/elections/create"
        class="inline-flex items-center px-4 py-2 bg-secondary text-white rounded-lg hover:bg-secondary/90 transition-colors focus:ring-2 focus:ring-secondary focus:ring-offset-2"
      >
        <Plus size="18" stroke-width={2} class="mr-2" />
        New Election
      </a>
    </div>

    <!-- Elections Table -->
    {
      elections.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">
                  Name
                </th>
                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">
                  Description
                </th>
                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">
                  Races
                </th>
                <th class="px-4 py-3 text-right text-sm font-semibold text-gray-700">
                  Actions
                </th>
              </tr>
            </thead>
            <tbody>
              {elections.map((election) => (
                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-3 text-sm font-medium text-gray-900">
                    {election.name}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-600">
                    {election.description.substring(0, 50)}
                    {election.description.length > 50 && "..."}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-600">
                    {election.races.length} race
                    {election.races.length !== 1 ? "s" : ""}
                  </td>
                  <td class="px-4 py-3 text-sm text-right space-x-2">
                    <a
                      href={`/admin/elections/${election.slug}/edit`}
                      class="inline-flex items-center px-3 py-1 bg-blue-100 text-blue-700 rounded-md hover:bg-blue-200 transition-colors text-xs font-medium"
                    >
                      Edit
                    </a>
                    <a
                      href={`/admin/elections/${election.slug}/races`}
                      class="inline-flex items-center px-3 py-1 bg-green-100 text-green-700 rounded-md hover:bg-green-200 transition-colors text-xs font-medium"
                    >
                      Races
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-gray-500">
            No elections yet. Create one to get started!
          </p>
        </div>
      )
    }
  </div>
</AdminLayout>

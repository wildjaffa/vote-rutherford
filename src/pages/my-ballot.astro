---
import Layout from "../layouts/Layout.astro";
import PersonalizedBallot from "../components/PersonalizedBallot.astro";

export const prerender = false;

const urlGroupId = Astro.url.searchParams.get("groupId");
---

<Layout
  description="For residents of Rutherford County Tennessee, view your personalized ballot for the upcoming election based on your address"
  title="My Ballot"
>
  <main class="mx-auto flex-1 px-4 py-8">
    <PersonalizedBallot groupId={urlGroupId} />
  </main>
</Layout>

<script>
  // Simplified logic: If we have a groupId in localStorage but NOT in the URL,
  // we perform a one-time redirect to the canonical URL for that address group.
  // This ensures the server-side rendering (SSR) is utilized and the result is
  // cached at the edge for 4 hours by the middleware.
  const localId = localStorage.getItem("voterGroupId");
  const urlParams = new URLSearchParams(window.location.search);
  const urlGroupId = urlParams.get("groupId");

  if (localId && urlGroupId !== localId) {
    window.location.href = `/my-ballot?groupId=${localId}`;
  }
</script>

---
import Layout from "../../layouts/Layout.astro";
import prisma from "../../lib/prisma";
import ElectionCard from "../../components/ElectionCard.astro";
import type { ElectionWithRacesAndCandidates } from "../../lib/types";

// Fetch all elections ordered by date (newest first)
// Include races to get the count for the card
const elections = await prisma.election.findMany({
  orderBy: {
    date: "desc",
  },
  include: {
    races: {
      include: {
        candidates: true,
      },
    },
  },
});
---

<Layout title="Elections">
  <main class="container mx-auto px-4 py-8">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Elections</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Browse upcoming and past elections in Rutherford County.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        elections.length > 0 ? (
          elections.map((election: ElectionWithRacesAndCandidates) => (
            <ElectionCard election={election} />
          ))
        ) : (
          <div class="col-span-full text-center py-12">
            <p class="text-gray-500 text-lg">No elections found.</p>
          </div>
        )
      }
    </div>
  </main>
</Layout>

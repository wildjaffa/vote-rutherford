---
import Layout from "../../../layouts/Layout.astro";
import RaceCard from "../../../components/RaceCard.astro";
import prisma from "../../../lib/prisma";

export const prerender = false;

const { election } = Astro.params;

if (!election) {
  return Astro.redirect("/404");
}

const electionData = await prisma.election.findUnique({
  where: { slug: election },
  include: {
    races: {
      include: {
        candidates: {
          include: {
            profileImage: true,
          },
        },
      },
    },
  },
});

if (!electionData) {
  return Astro.redirect("/404");
}
---

<Layout title={`${electionData.name} | Races`}>
  <main class="container mx-auto px-4 py-8">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        {electionData.name}
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        {electionData.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        electionData.races.length > 0 ? (
          electionData.races.map((race) => (
            <RaceCard
              election={electionData}
              race={race}
              candidates={race.candidates}
            />
          ))
        ) : (
          <div class="col-span-full text-center py-12">
            <p class="text-gray-500 text-lg">
              No races found for this election.
            </p>
          </div>
        )
      }
    </div>
  </main>
</Layout>

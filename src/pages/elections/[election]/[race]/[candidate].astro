---
import type {
  CandidatePolicyResponse,
  CandidateExternalLink,
  CandidateQualification,
} from "../../../../generated/prisma/browser";
import Layout from "../../../../layouts/Layout.astro";
import prisma from "../../../../lib/prisma";

export async function getStaticPaths() {
  const candidates = await prisma.candidate.findMany({
    include: {
      race: {
        include: {
          election: true,
        },
      },
    },
  });

  return candidates.map((candidate: any) => ({
    params: {
      election: candidate.race.election.slug,
      race: candidate.race.slug,
      candidate: candidate.slug,
    },
  }));
}

const { election, race, candidate } = Astro.params;

if (!election || !race || !candidate) {
  return Astro.redirect("/404");
}

const candidateData = await prisma.candidate.findFirst({
  where: {
    slug: candidate,
    race: {
      slug: race,
      election: {
        slug: election,
      },
    },
  },
  include: {
    race: {
      include: {
        election: true,
      },
    },
    profileImage: true,
    historicalLink: true,
    externalLinks: {
      include: {
        externalLinkType: true,
      },
    },
    qualifications: {
      include: {
        qualificationType: true,
      },
    },
    policyResponses: {
      include: {
        policyQuestion: true,
      },
    },
  },
});

if (!candidateData) {
  return Astro.redirect("/404");
}

const fullName = `${candidateData.firstName} ${candidateData.middleName ? candidateData.middleName + " " : ""}${candidateData.lastName}`;
const imageUrl = candidateData.profileImage
  ? `/${candidateData.profileImage.fileLocation}`
  : null;
---

<Layout title={`${fullName} | ${candidateData.race.election.name}`}>
  <main class="container mx-auto px-4 py-8">
    <div class="mb-6">
      <a href={`/elections/${election}`} class="text-blue-600 hover:underline"
        >&larr; Back to {candidateData.race.election.name}</a
      >
    </div>

    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
      <div class="md:flex">
        <div
          class="md:shrink-0 bg-gray-100 flex items-center justify-center w-full md:w-48 h-48 md:h-auto"
        >
          {
            imageUrl ? (
              <img
                class="h-48 w-full object-cover md:h-full md:w-48"
                src={imageUrl}
                alt={fullName}
              />
            ) : (
              <div class="text-gray-400">
                <svg
                  class="h-24 w-24 mx-auto"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </div>
            )
          }
        </div>
        <div class="p-8">
          <div
            class="uppercase tracking-wide text-sm text-indigo-500 font-semibold"
          >
            {candidateData.race.name}
          </div>
          <h1 class="mt-1 text-4xl font-bold text-gray-900 leading-tight">
            {fullName}
          </h1>
          <p class="mt-2 text-gray-500">
            Running in the {candidateData.race.election.name}
          </p>

          {
            candidateData.biography && (
              <div class="mt-4 prose max-w-none text-gray-600">
                <h3 class="text-lg font-semibold text-gray-800">Biography</h3>
                <p>{candidateData.biography}</p>
              </div>
            )
          }

          {
            candidateData.qualifications.length > 0 && (
              <div class="mt-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-2">
                  Qualifications
                </h3>
                <ul class="list-disc list-inside text-gray-600 space-y-1">
                  {candidateData.qualifications.map(
                    (qual: CandidateQualification) => (
                      <li>
                        <span class="font-medium">
                          {qual.qualificationType.value === "education"
                            ? "Education"
                            : qual.qualificationType.value === "work_experience"
                              ? "Experience"
                              : "Qualification"}
                          :
                        </span>{" "}
                        {qual.qualification_description}
                      </li>
                    ),
                  )}
                </ul>
              </div>
            )
          }

          {
            candidateData.externalLinks.length > 0 && (
              <div class="mt-6 flex space-x-4">
                {candidateData.externalLinks.map(
                  (link: CandidateExternalLink) => (
                    <a
                      href={link.hyperlink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-blue-600 hover:text-blue-800 capitalize"
                    >
                      {link.externalLinkType.value}
                    </a>
                  ),
                )}
              </div>
            )
          }
        </div>
      </div>
    </div>

    {
      candidateData.policyResponses.length > 0 && (
        <div class="mt-8 bg-white shadow-lg rounded-lg p-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">
            Policy Positions
          </h2>
          <div class="space-y-6">
            {candidateData.policyResponses.map(
              (resp: CandidatePolicyResponse) => (
                <div class="border-b border-gray-200 pb-4 last:border-0 last:pb-0">
                  <h3 class="text-lg font-semibold text-indigo-600 mb-2">
                    {resp.policyQuestion.questiontext}
                  </h3>
                  <p class="text-gray-700 italic mb-2">
                    "{resp.policyQuestion.descriptionText}"
                  </p>
                  <div class="bg-gray-50 p-4 rounded-md">
                    <p class="text-gray-800">{resp.response}</p>
                  </div>
                </div>
              ),
            )}
          </div>
        </div>
      )
    }
  </main>
</Layout>

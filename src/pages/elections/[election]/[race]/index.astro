---
import Layout from "../../../../layouts/Layout.astro";
import CandidateCard from "../../../../components/CandidateCard.astro";
import type { PolicyQuestion } from "../../../../generated/prisma/client";
import prisma from "../../../../lib/prisma";
import { convertKeyToPublicUrl } from "../../../../lib/blobStorage";
import { ArrowLeft } from "../../../../lib/icons";

export const prerender = false;

const { election, race } = Astro.params;

if (!election || !race) {
  return Astro.redirect("/404");
}

const raceData = await prisma.race.findFirst({
  where: {
    slug: race,
    election: { slug: election },
  },
  include: {
    election: { include: { policyQuestions: true } },
    candidates: {
      include: {
        profileImage: true,
        policyResponses: true,
      },
    },
  },
});

if (raceData === null) {
  return Astro.redirect("/404");
}

const questions = raceData.election.policyQuestions;
const { candidates } = raceData;
---

<Layout title={`${raceData.name} | ${raceData.election.name}`}>
  <main class="container mx-auto px-4 py-8">
    <div class="mb-6">
      <a
        href={`/elections/${election}`}
        class="group flex w-fit items-center text-blue-600 hover:text-blue-800"
      >
        <ArrowLeft
          size={20}
          class="mr-2 transition-transform group-hover:-translate-x-1"
        />
        Back to {raceData.election.name}
      </a>
    </div>

    <div class="mb-12">
      <h1 class="mb-4 text-4xl font-bold text-gray-900">{raceData.name}</h1>
      <p class="max-w-3xl text-xl text-gray-600">{raceData.description}</p>
    </div>

    <section class="mb-16">
      <h2 class="mb-6 text-2xl font-semibold text-gray-900">Candidates</h2>
      {
        candidates.length > 0 ? (
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {candidates.map((candidate) => (
              <CandidateCard
                candidate={candidate}
                raceSlug={raceData.slug}
                electionSlug={raceData.election.slug}
                profileImage={candidate.profileImage}
              />
            ))}
          </div>
        ) : (
          <p class="text-gray-500 italic">No candidates found for this race.</p>
        )
      }
    </section>

    {
      questions.length > 0 && candidates.length > 0 && (
        <section>
          <h2 class="mb-8 text-2xl font-semibold text-gray-900">
            Policy Comparison
          </h2>
          <div class="space-y-12">
            {questions.map((question: PolicyQuestion) => (
              <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                <div class="border-b border-gray-200 bg-gray-50 p-6">
                  <h3 class="text-xl font-bold text-gray-900">
                    {question.questionText}
                  </h3>
                  <p class="mt-2 text-gray-600">{question.descriptionText}</p>
                </div>

                <div class="grid grid-cols-1 gap-8 p-6 lg:grid-cols-2">
                  <div>
                    <label class="mb-2 block text-sm font-medium text-gray-700">
                      Your Stance
                    </label>
                    <textarea
                      class="focus:ring-secondary focus:border-secondary h-40 w-full resize-none rounded-lg border border-gray-300 p-3 focus:ring-2"
                      placeholder="Type your thoughts here to compare directly with the candidates..."
                    />
                  </div>

                  <div class="custom-scrollbar max-h-125 space-y-4 overflow-y-auto pr-2">
                    <h4 class="mb-3 text-sm font-medium tracking-wider text-gray-700 uppercase">
                      Candidate Responses
                    </h4>
                    {candidates.map((candidate) => {
                      const response = candidate.policyResponses.find(
                        (r) => r.policyQuestionId === question.id,
                      );

                      return (
                        <div class="relative rounded-lg bg-gray-50 p-4">
                          <div class="mb-2 flex items-center gap-3">
                            <div class="h-8 w-8 shrink-0 overflow-hidden rounded-full bg-gray-200">
                              {candidate.profileImage ? (
                                <img
                                  src={convertKeyToPublicUrl(
                                    candidate.profileImage.fileLocation,
                                  )}
                                  alt={candidate.lastName}
                                  class="h-full w-full object-cover"
                                />
                              ) : (
                                <div class="flex h-full w-full items-center justify-center text-xs text-gray-400">
                                  ?
                                </div>
                              )}
                            </div>
                            <span class="font-semibold text-gray-900">
                              {candidate.firstName} {candidate.lastName}
                            </span>
                          </div>

                          {response ? (
                            <p class="text-sm leading-relaxed text-gray-800">
                              {response.response}
                            </p>
                          ) : (
                            <p class="text-sm text-gray-500 italic">
                              No response provided.
                            </p>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #e5e7eb;
    border-radius: 20px;
  }
</style>

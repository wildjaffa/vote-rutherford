---
import Layout from "../../../../layouts/Layout.astro";
import prisma from "../../../../lib/prisma";
import CandidateCard from "../../../../components/CandidateCard.astro";
import { ArrowLeft } from "@lucide/astro";
import type { RaceWithCandidates } from "../../../../lib/types";
import { GET } from "../../../api/elections/[election]/races/[race].json.ts";
import type {
  Candidate,
  CandidatePolicyResponse,
} from "../../../../generated/prisma/browser";
import type { PolicyQuestion } from "../../../../generated/prisma/client";

export async function getStaticPaths() {
  const races = await prisma.race.findMany({
    include: {
      election: true,
    },
  });

  return races.map((race: RaceWithCandidates) => ({
    params: {
      election: race.election.slug,
      race: race.slug,
    },
  }));
}

const { election, race } = Astro.params;

if (!election || !race) {
  return Astro.redirect("/404");
}

const response = await GET(Astro);
if (response.status === 404) {
  return Astro.redirect("/404");
}

const { race: raceData, questions } = await response.json();

if (!raceData) {
  return Astro.redirect("/404");
}

const { candidates } = raceData;
---

<Layout title={`${raceData.name} | ${raceData.election.name}`}>
  <main class="container mx-auto px-4 py-8">
    <div class="mb-6">
      <a
        href={`/elections/${election}`}
        class="text-blue-600 hover:text-blue-800 flex items-center group w-fit"
      >
        <ArrowLeft
          size={20}
          class="mr-2 group-hover:-translate-x-1 transition-transform"
        />
        Back to {raceData.election.name}
      </a>
    </div>

    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{raceData.name}</h1>
      <p class="text-xl text-gray-600 max-w-3xl">{raceData.description}</p>
    </div>

    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-gray-900 mb-6">Candidates</h2>
      {
        candidates.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {candidates.map((candidate: Candidate) => (
              <CandidateCard
                candidate={candidate}
                raceSlug={raceData.slug}
                electionSlug={raceData.election.slug}
              />
            ))}
          </div>
        ) : (
          <p class="text-gray-500 italic">No candidates found for this race.</p>
        )
      }
    </section>

    {
      questions.length > 0 && candidates.length > 0 && (
        <section>
          <h2 class="text-2xl font-semibold text-gray-900 mb-8">
            Policy Comparison
          </h2>
          <div class="space-y-12">
            {questions.map((question: PolicyQuestion) => (
              <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="bg-gray-50 p-6 border-b border-gray-200">
                  <h3 class="text-xl font-bold text-gray-900">
                    {question.questiontext}
                  </h3>
                  <p class="text-gray-600 mt-2">{question.descriptionText}</p>
                </div>

                <div class="p-6 grid grid-cols-1 lg:grid-cols-2 gap-8">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                      Your Stance
                    </label>
                    <textarea
                      class="w-full h-40 p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-secondary resize-none"
                      placeholder="Type your thoughts here to compare directly with the candidates..."
                    />
                  </div>

                  <div class="space-y-4 max-h-[500px] overflow-y-auto pr-2 custom-scrollbar">
                    <h4 class="text-sm font-medium text-gray-700 uppercase tracking-wider mb-3">
                      Candidate Responses
                    </h4>
                    {candidates.map((candidate: Candidate) => {
                      const response = candidate.policyResponses.find(
                        (r: CandidatePolicyResponse) =>
                          r.policyQuestionId === question.id,
                      );

                      return (
                        <div class="bg-gray-50 rounded-lg p-4 relative">
                          <div class="flex items-center gap-3 mb-2">
                            <div class="h-8 w-8 rounded-full bg-gray-200 overflow-hidden shrink-0">
                              {candidate.profileImage ? (
                                <img
                                  src={`/${candidate.profileImage.fileLocation}`}
                                  alt={candidate.lastName}
                                  class="h-full w-full object-cover"
                                />
                              ) : (
                                <div class="h-full w-full flex items-center justify-center text-gray-400 text-xs">
                                  ?
                                </div>
                              )}
                            </div>
                            <span class="font-semibold text-gray-900">
                              {candidate.firstName} {candidate.lastName}
                            </span>
                          </div>

                          {response ? (
                            <p class="text-gray-800 text-sm leading-relaxed">
                              {response.response}
                            </p>
                          ) : (
                            <p class="text-gray-500 text-sm italic">
                              No response provided.
                            </p>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: #e5e7eb;
    border-radius: 20px;
  }
</style>
